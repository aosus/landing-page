    "test": "vitest run"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.23.24",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.545.0",
    "next": "^15.3.1",
    "open-graph-scraper": "^6.11.0",
    "p-limit": "^7.2.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-icons": "^5.6.0",
    "remark": "^15.0.1",
    "remark-html": "^16.0.1",
    "sharp": "^0.33.5",
    "tailwind-merge": "^3.3.1",
    "turndown": "^7.2.4",
    "unist-util-visit": "^5.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.4",
    "@tailwindcss/typography": "^0.5.15",
