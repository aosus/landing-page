  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.18.1"
  },
  "scripts": {
    "dev": "tsx scripts/sync-content-assets.ts && tsx scripts/build-link-previews.ts && next dev --port ${PORT:-25211} --hostname 0.0.0.0",
