4:["$","$Lf",null,{"post":{"title":"Aosus Partners with Hack Club Foundation","date":"2024-06-15","author":"FarisZR","tags":["Community","Partnership","Nonprofit"],"thumbnail":"/images/hero-4.png","ogImage":"/og/hero-4.jpg","excerpt":"Aosus is now fiscally sponsored by The Hack Foundation, gaining 501(c)(3) nonprofit status for tax-deductible donations.","slug":"hcb-partnership","lang":"en","content":"<p>We are excited to announce that the Aosus community is now fiscally sponsored by The Hack Foundation (d.b.a. Hack Club), a 501(c)(3) nonprofit organization.</p>\n<p>This partnership means that donations to Aosus are now tax-deductible in the United States. It also provides us with a solid financial infrastructure through Hack Club Bank (HCB), ensuring full transparency in how community funds are managed.</p>\n<p>All financial transactions are publicly visible on our HCB page, reflecting our commitment to transparency and accountability in how we handle community resources.</p>\n<p>This milestone allows us to better support our mission of promoting free and open-source software in the Arabic world, fund community events, and maintain our privacy-respecting services.</p>\n"},"prevPost":{"title":"Writing Contest: October Winners Announced","date":"2022-10-30","author":"FarisZR","tags":["Writing Contest","Community","Awards"],"thumbnail":"/images/hero-5.png","ogImage":"/og/hero-5.jpg","excerpt":"Valuable and detailed topics on free and open-source software win the Aosus Writing Award for October!","slug":"writing-contest-october-winners","lang":"en"},"lang":"en"}]
