---
import '../../styles/global.css';
const base = import.meta.env.GITHUB_ACTIONS ? '/landing-page' : '';
---

<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="أسس - أكبر مجتمع عربي للبرمجيات الحرة والمفتوحة المصدر" />
  <title>أسس - مجتمع البرمجيات الحرة والمفتوحة المصدر</title>
  <link rel="icon" type="image/svg+xml" href="/brand/aosus-icon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Amiri:wght@400;700&family=IBM+Plex+Mono:wght@400;500;600&family=IBM+Plex+Sans+Arabic:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    :root {
      --parchment: #f0ebe0;
      --parchment-alt: #e6e0d3;
      --ink: #1c1a16;
      --ink-light: #4d4a42;
      --ink-lighter: #8a8578;
      --border: #c4bfb2;
      --border-light: #d9d4c7;
      --green: #008a2f;
      --green-hover: #006b24;
      --blue: #1d70ba;
    }
    .dark {
      --parchment: #121210;
      --parchment-alt: #1a1a17;
      --ink: #d6d2c8;
      --ink-light: #a09c90;
      --ink-lighter: #5e5b52;
      --border: #2e2c28;
      --border-light: #242220;
      --green: #00a63a;
      --green-hover: #00c445;
      --blue: #4a9ede;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'IBM Plex Sans Arabic', sans-serif;
      background: var(--parchment);
      color: var(--ink);
      -webkit-font-smoothing: antialiased;
    }
    .serif { font-family: 'Amiri', serif; }
    .mono {
      font-family: 'IBM Plex Mono', monospace;
    }
    .label {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.6875rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--ink-lighter);
    }
    html { scroll-behavior: smooth; }
    a { text-decoration: none; color: inherit; }
    .container { max-width: 1200px; margin: 0 auto; padding: 0 24px; }
    @media (min-width: 768px) { .container { padding: 0 40px; } }
    @media (min-width: 1024px) { .container { padding: 0 48px; } }

    .b-bottom { border-bottom: 1px solid var(--border); }
    .b-top { border-top: 1px solid var(--border); }
    .b-right { border-right: 1px solid var(--border); }
    .b-all { border: 1px solid var(--border); }

    .mobile-menu { display: none; }
    .mobile-menu.active { display: block; }

    /* Ink reveal animation — sections start masked, reveal with ink wash */
    .ink-section {
      position: relative;
      overflow: hidden;
    }
    .ink-section .ink-mask {
      position: absolute;
      top: 0; left: 0;
      width: 100%; height: 100%;
      pointer-events: none;
      z-index: 2;
      opacity: 1;
      transition: opacity 1.2s ease;
    }
    .ink-section.revealed .ink-mask {
      opacity: 0;
    }

    /* Content reveal */
    .ink-content {
      opacity: 0;
      transform: translateY(16px);
      transition: opacity 0.8s ease 0.3s, transform 0.8s ease 0.3s;
    }
    .ink-section.revealed .ink-content {
      opacity: 1;
      transform: translateY(0);
    }

    /* Simple reveal for non-ink sections */
    .reveal {
      opacity: 0;
      transform: translateY(10px);
      transition: opacity 0.5s ease, transform 0.5s ease;
    }
    .reveal.visible { opacity: 1; transform: translateY(0); }

    /* Ink stroke decoration */
    .ink-stroke {
      position: relative;
      display: inline-block;
    }
    .ink-stroke::after {
      content: '';
      position: absolute;
      bottom: -4px;
      right: 0;
      width: 0;
      height: 2px;
      background: var(--ink);
      transition: width 1s ease;
    }
    .ink-section.revealed .ink-stroke::after {
      width: 100%;
    }
  </style>
</head>
<body>

  <!-- Ink Wash Canvas (used for transition effects) -->
  <canvas id="ink-canvas" style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; z-index: 100; opacity: 0; transition: opacity 0.5s ease;"></canvas>

  <!-- NAVIGATION -->
  <nav class="b-bottom" style="position: fixed; top: 0; left: 0; right: 0; z-index: 200; background: var(--parchment); height: 56px;">
    <div class="container" style="display: flex; align-items: center; justify-content: space-between; height: 100%;">
      <a href={base + "/9/"} style="display: flex; align-items: center; gap: 10px;">
        <img src="/brand/aosus-icon.svg" alt="أسس" style="width: 28px; height: 28px;" />
        <span class="serif" style="font-weight: 700; font-size: 1.25rem;">أسس</span>
      </a>
      <div style="display: none; align-items: center; gap: 28px; font-size: 0.8125rem; color: var(--ink-light);" class="nav-desktop">
        <a href="#about" style="transition: color 0.2s;" onmouseover="this.style.color='var(--ink)'" onmouseout="this.style.color='var(--ink-light)'">من نحن</a>
        <a href="#services" style="transition: color 0.2s;" onmouseover="this.style.color='var(--ink)'" onmouseout="this.style.color='var(--ink-light)'">الخدمات</a>
        <a href="#contest" style="transition: color 0.2s;" onmouseover="this.style.color='var(--ink)'" onmouseout="this.style.color='var(--ink-light)'">الجائزة</a>
        <a href="#timeline" style="transition: color 0.2s;" onmouseover="this.style.color='var(--ink)'" onmouseout="this.style.color='var(--ink-light)'">تاريخنا</a>
        <a href="#projects" style="transition: color 0.2s;" onmouseover="this.style.color='var(--ink)'" onmouseout="this.style.color='var(--ink-light)'">المشاريع</a>
        <a href="#support" style="transition: color 0.2s;" onmouseover="this.style.color='var(--ink)'" onmouseout="this.style.color='var(--ink-light)'">ادعمنا</a>
      </div>
      <div style="display: flex; align-items: center; gap: 8px;">
        <button id="theme-toggle" style="width: 32px; height: 32px; display: flex; align-items: center; justify-content: center; background: none; border: none; color: var(--ink-light); cursor: pointer;" aria-label="تبديل المظهر">
          <svg class="theme-moon" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z" /></svg>
          <svg class="theme-sun" style="display:none;" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="4" /><path d="M12 2v2m0 16v2M4.93 4.93l1.41 1.41m11.32 11.32l1.41 1.41M2 12h2m16 0h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41" /></svg>
        </button>
        <button id="mobile-toggle" style="display: none; width: 32px; height: 32px; align-items: center; justify-content: center; background: none; border: none; color: var(--ink-light); cursor: pointer;" class="mobile-toggle-btn" aria-label="القائمة">
          <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M3.75 9h16.5m-16.5 6h16.5" /></svg>
        </button>
      </div>
    </div>
    <div id="mobile-menu" class="mobile-menu b-top" style="background: var(--parchment); padding: 0 24px 16px;">
      <div style="display: flex; flex-direction: column; font-size: 0.875rem; color: var(--ink-light);">
        <a href="#about" style="padding: 10px 0; border-bottom: 1px solid var(--border-light);">من نحن</a>
        <a href="#services" style="padding: 10px 0; border-bottom: 1px solid var(--border-light);">الخدمات</a>
        <a href="#contest" style="padding: 10px 0; border-bottom: 1px solid var(--border-light);">الجائزة</a>
        <a href="#timeline" style="padding: 10px 0; border-bottom: 1px solid var(--border-light);">تاريخنا</a>
        <a href="#projects" style="padding: 10px 0; border-bottom: 1px solid var(--border-light);">المشاريع</a>
        <a href="#support" style="padding: 10px 0;">ادعمنا</a>
      </div>
    </div>
  </nav>

  <!-- HERO -->
  <section class="ink-section" style="padding-top: 56px;">
    <div class="container">
      <div class="b-bottom" style="padding: 80px 0 60px;">
        <div class="ink-content">
          <span class="label" style="display: block; margin-bottom: 24px;">مجتمع مفتوح المصدر</span>
          <h1 class="serif" style="font-size: clamp(3rem, 8vw, 6rem); font-weight: 700; line-height: 1.1; margin: 0 0 32px; max-width: 800px;">
            <span class="ink-stroke">أكبر مجتمع عربي</span>
            <br />للبرمجيات الحرة
            <br />والمفتوحة المصدر
          </h1>
          <p style="font-size: 1.125rem; color: var(--ink-light); line-height: 1.8; max-width: 560px; margin: 0 0 48px;">
            مجتمع غير ربحي أسسه مجموعة من التقنيين العرب بهدف نشر ثقافة المصادر المفتوحة والبرمجيات الحرة في العالم العربي
          </p>
        </div>
        <div class="ink-content" style="display: flex; flex-wrap: wrap; gap: 12px; margin-bottom: 64px;">
          <a href="https://discourse.aosus.org" style="display: inline-flex; align-items: center; padding: 10px 28px; background: var(--green); color: #fff; font-size: 0.875rem; font-weight: 500; transition: background 0.2s;" onmouseover="this.style.background='var(--green-hover)'" onmouseout="this.style.background='var(--green)'">
            انضم للمجتمع
          </a>
          <a href="#about" style="display: inline-flex; align-items: center; padding: 10px 28px; border: 1px solid var(--border); font-size: 0.875rem; color: var(--ink-light); transition: border-color 0.2s, color 0.2s;" onmouseover="this.style.borderColor='var(--ink)';this.style.color='var(--ink)'" onmouseout="this.style.borderColor='var(--border)';this.style.color='var(--ink-light)'">
            تعرّف علينا
          </a>
        </div>
      </div>

      <!-- Stats -->
      <div class="ink-content" style="display: grid; grid-template-columns: repeat(4, 1fr);">
        <div class="b-bottom" style="padding: 32px 0;">
          <div class="serif" style="font-size: clamp(2rem, 4vw, 3.5rem); font-weight: 700;">6,000<span style="color: var(--green);">+</span></div>
          <div class="label" style="margin-top: 8px;">عضو</div>
        </div>
        <div class="b-bottom b-right" style="padding: 32px 24px;">
          <div class="serif" style="font-size: clamp(2rem, 4vw, 3.5rem); font-weight: 700;">5,000<span style="color: var(--green);">+</span></div>
          <div class="label" style="margin-top: 8px;">مشاركة</div>
        </div>
        <div class="b-bottom b-right" style="padding: 32px 24px;">
          <div class="serif" style="font-size: clamp(2rem, 4vw, 3.5rem); font-weight: 700;">10</div>
          <div class="label" style="margin-top: 8px;">سنوات</div>
        </div>
        <div class="b-bottom b-right" style="padding: 32px 24px;">
          <div class="serif" style="font-size: clamp(2rem, 4vw, 3.5rem); font-weight: 700;">3,000<span style="color: var(--green);">+</span></div>
          <div class="label" style="margin-top: 8px;">موضوع</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ABOUT -->
  <section id="about" class="ink-section" style="padding: 96px 0;">
    <div class="container">
      <div class="b-bottom" style="padding-bottom: 96px;">
        <div class="ink-content">
          <span class="label" style="display: block; margin-bottom: 20px;">01 — من نحن</span>
          <h2 class="serif" style="font-size: clamp(2.5rem, 5vw, 3.5rem); font-weight: 700; line-height: 1.2; margin: 0 0 24px;">
            <span class="ink-stroke">نبني مجتمعاً عربياً مفتوح المصدر</span>
          </h2>
          <p style="font-size: 1rem; color: var(--ink-light); line-height: 1.9; max-width: 640px;">
            نسعى لنشر ثقافة البرمجيات الحرة والمفتوحة المصدر في العالم العربي. نؤمن بأن التقنية يجب أن تكون متاحة للجميع وأن المعرفة حق مشترك.
          </p>
        </div>

        <!-- Vision & Mission -->
        <div class="ink-content" style="display: grid; grid-template-columns: 1fr 1fr; gap: 0; margin-top: 64px;" class="vision-grid">
          <div style="padding: 32px; border: 1px solid var(--border);">
            <span class="label" style="display: block; margin-bottom: 16px;">الرؤية</span>
            <p style="font-size: 0.9375rem; color: var(--ink-light); line-height: 1.8;">
              أن يكون العالم العربي رائداً في استخدام وتطوير البرمجيات الحرة والمفتوحة المصدر
            </p>
          </div>
          <div style="padding: 32px; border: 1px solid var(--border); border-right: none;">
            <span class="label" style="display: block; margin-bottom: 16px;">الرسالة</span>
            <p style="font-size: 0.9375rem; color: var(--ink-light); line-height: 1.8;">
              نشر ثقافة المصادر المفتوحة والبرمجيات الحرة وتعزيز استخدامها في المجتمع العربي
            </p>
          </div>
        </div>

        <!-- Values -->
        <div class="ink-content" style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 0; margin-top: 0;" class="values-grid">
          <div style="padding: 24px; border: 1px solid var(--border); border-top: none;">
            <div style="width: 6px; height: 6px; border-radius: 50%; background: var(--green); margin-bottom: 16px;"></div>
            <div style="font-weight: 600; margin-bottom: 8px;">التعاون</div>
            <div style="font-size: 0.8125rem; color: var(--ink-lighter); line-height: 1.7;">العمل الجماعي أساس نجاحنا</div>
          </div>
          <div style="padding: 24px; border: 1px solid var(--border); border-right: none; border-top: none;">
            <div style="width: 6px; height: 6px; border-radius: 50%; background: var(--green); margin-bottom: 16px;"></div>
            <div style="font-weight: 600; margin-bottom: 8px;">الشفافية</div>
            <div style="font-size: 0.8125rem; color: var(--ink-lighter); line-height: 1.7;">الوضوح في كل ما نقوم به</div>
          </div>
          <div style="padding: 24px; border: 1px solid var(--border); border-right: none; border-top: none;">
            <div style="width: 6px; height: 6px; border-radius: 50%; background: var(--green); margin-bottom: 16px;"></div>
            <div style="font-weight: 600; margin-bottom: 8px;">الخصوصية</div>
            <div style="font-size: 0.8125rem; color: var(--ink-lighter); line-height: 1.7;">حماية بيانات المستخدمين</div>
          </div>
          <div style="padding: 24px; border: 1px solid var(--border); border-right: none; border-top: none;">
            <div style="width: 6px; height: 6px; border-radius: 50%; background: var(--green); margin-bottom: 16px;"></div>
            <div style="font-weight: 600; margin-bottom: 8px;">المسؤولية</div>
            <div style="font-size: 0.8125rem; color: var(--ink-lighter); line-height: 1.7;">التزامنا تجاه المجتمع</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section id="services" class="ink-section" style="background: var(--parchment-alt);">
    <div class="container" style="padding-top: 96px; padding-bottom: 96px;">
      <div class="ink-content">
        <span class="label" style="display: block; margin-bottom: 20px;">02 — الخدمات</span>
        <h2 class="serif" style="font-size: clamp(2.5rem, 5vw, 3.5rem); font-weight: 700; line-height: 1.2; margin: 0 0 16px;">خدمات مجانية تحترم خصوصيتك</h2>
        <p style="font-size: 1rem; color: var(--ink-light); line-height: 1.8; max-width: 560px; margin: 0 0 56px;">
          نقدم بدائل مفتوحة المصدر تحترم خصوصيتك للخدمات المغلقة الأكثر استخداماً
        </p>
      </div>

      <!-- Services as bordered list (D1-style with D5 numbering) -->
      <div class="ink-content">
        <div class="b-top">
          <a href="#" style="display: flex; align-items: center; justify-content: space-between; padding: 20px 0; border-bottom: 1px solid var(--border); transition: padding-right 0.3s;" class="service-item" onmouseover="this.style.paddingRight='16px'" onmouseout="this.style.paddingRight='0'">
            <div style="display: flex; align-items: baseline; gap: 16px;">
              <span class="mono" style="font-size: 0.6875rem; min-width: 20px;">01</span>
              <div>
                <span style="font-weight: 600;">SearXNG</span>
                <span style="color: var(--ink-lighter); font-size: 0.875rem; margin-right: 12px;">— محرك بحث يحترم الخصوصية</span>
              </div>
            </div>
            <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="var(--ink-lighter)" stroke-width="1.5" style="flex-shrink: 0;"><path d="M7 17L17 7M17 7H7M17 7v10" /></svg>
          </a>
          <a href="#" style="display: flex; align-items: center; justify-content: space-between; padding: 20px 0; border-bottom: 1px solid var(--border); transition: padding-right 0.3s;" class="service-item" onmouseover="this.style.paddingRight='16px'" onmouseout="this.style.paddingRight='0'">
            <div style="display: flex; align-items: baseline; gap: 16px;">
              <span class="mono" style="font-size: 0.6875rem; min-width: 20px;">02</span>
              <div>
                <span style="font-weight: 600;">Simply Translate</span>
                <span style="color: var(--ink-lighter); font-size: 0.875rem; margin-right: 12px;">— ترجمة بديلة لـ Google Translate</span>
              </div>
            </div>
            <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="var(--ink-lighter)" stroke-width="1.5" style="flex-shrink: 0;"><path d="M7 17L17 7M17 7H7M17 7v10" /></svg>
          </a>
          <a href="#" style="display: flex; align-items: center; justify-content: space-between; padding: 20px 0; border-bottom: 1px solid var(--border); transition: padding-right 0.3s;" class="service-item" onmouseover="this.style.paddingRight='16px'" onmouseout="this.style.paddingRight='0'">
            <div style="display: flex; align-items: baseline; gap: 16px;">
              <span class="mono" style="font-size: 0.6875rem; min-width: 20px;">03</span>
              <div>
                <span style="font-weight: 600;">Nitter</span>
                <span style="color: var(--ink-lighter); font-size: 0.875rem; margin-right: 12px;">— واجهة بديلة لـ Twitter</span>
              </div>
            </div>
            <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="var(--ink-lighter)" stroke-width="1.5" style="flex-shrink: 0;"><path d="M7 17L17 7M17 7H7M17 7v10" /></svg>
          </a>
          <a href="#" style="display: flex; align-items: center; justify-content: space-between; padding: 20px 0; border-bottom: 1px solid var(--border); transition: padding-right 0.3s;" class="service-item" onmouseover="this.style.paddingRight='16px'" onmouseout="this.style.paddingRight='0'">
            <div style="display: flex; align-items: baseline; gap: 16px;">
              <span class="mono" style="font-size: 0.6875rem; min-width: 20px;">04</span>
              <div>
                <span style="font-weight: 600;">Redlib</span>
                <span style="color: var(--ink-lighter); font-size: 0.875rem; margin-right: 12px;">— واجهة بديلة لـ Reddit</span>
              </div>
            </div>
            <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="var(--ink-lighter)" stroke-width="1.5" style="flex-shrink: 0;"><path d="M7 17L17 7M17 7H7M17 7v10" /></svg>
          </a>
          <a href="#" style="display: flex; align-items: center; justify-content: space-between; padding: 20px 0; border-bottom: 1px solid var(--border); transition: padding-right 0.3s;" class="service-item" onmouseover="this.style.paddingRight='16px'" onmouseout="this.style.paddingRight='0'">
            <div style="display: flex; align-items: baseline; gap: 16px;">
              <span class="mono" style="font-size: 0.6875rem; min-width: 20px;">05</span>
              <div>
                <span style="font-weight: 600;">Element</span>
                <span style="color: var(--ink-lighter); font-size: 0.875rem; margin-right: 12px;">— تطبيق محادثة عبر Matrix</span>
              </div>
            </div>
            <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="var(--ink-lighter)" stroke-width="1.5" style="flex-shrink: 0;"><path d="M7 17L17 7M17 7H7M17 7v10" /></svg>
          </a>
          <a href="#" style="display: flex; align-items: center; justify-content: space-between; padding: 20px 0; border-bottom: 1px solid var(--border); transition: padding-right 0.3s;" class="service-item" onmouseover="this.style.paddingRight='16px'" onmouseout="this.style.paddingRight='0'">
            <div style="display: flex; align-items: baseline; gap: 16px;">
              <span class="mono" style="font-size: 0.6875rem; min-width: 20px;">06</span>
              <div>
                <span style="font-weight: 600;">rimgo</span>
                <span style="color: var(--ink-lighter); font-size: 0.875rem; margin-right: 12px;">— واجهة بديلة لـ Imgur</span>
              </div>
            </div>
            <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="var(--ink-lighter)" stroke-width="1.5" style="flex-shrink: 0;"><path d="M7 17L17 7M17 7H7M17 7v10" /></svg>
          </a>
          <a href="#" style="display: flex; align-items: center; justify-content: space-between; padding: 20px 0; border-bottom: 1px solid var(--border); transition: padding-right 0.3s;" class="service-item" onmouseover="this.style.paddingRight='16px'" onmouseout="this.style.paddingRight='0'">
            <div style="display: flex; align-items: baseline; gap: 16px;">
              <span class="mono" style="font-size: 0.6875rem; min-width: 20px;">07</span>
