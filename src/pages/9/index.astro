---
import '../../styles/global.css';
const base = import.meta.env.GITHUB_ACTIONS ? '/landing-page' : '';
---

<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="أسس - أكبر مجتمع عربي للبرمجيات الحرة والمفتوحة المصدر" />
  <title>أسس - مجتمع البرمجيات الحرة والمفتوحة المصدر</title>
  <link rel="icon" type="image/svg+xml" href="/brand/aosus-icon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Amiri:wght@400;700&family=IBM+Plex+Sans+Arabic:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    :root {
      --cream: #f4f1eb;
      --cream-dark: #e8e4dc;
      --ink: #1a1a18;
      --ink-light: #4a4a45;
      --ink-lighter: #8a8a82;
      --charcoal: #141416;
      --charcoal-light: #1e1e21;
      --charcoal-text: #d4d4cc;
      --charcoal-muted: #8a8a82;
    }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'IBM Plex Sans Arabic', sans-serif;
      background: var(--cream);
      color: var(--ink);
      position: relative;
    }
    .dark body {
      background: var(--charcoal);
      color: var(--charcoal-text);
    }
    .font-serif-ar {
      font-family: 'Amiri', serif;
    }
    .rule {
      border: none;
      border-top: 1px solid rgba(26, 26, 24, 0.12);
    }
    .dark .rule {
      border-top-color: rgba(212, 212, 204, 0.1);
    }
    .mobile-menu { display: none; }
    .mobile-menu.active { display: block; }

    /* Varied reveal animations */
    .reveal {
      opacity: 0;
      transition: opacity 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94), transform 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }
    .reveal.fade-up {
      transform: translateY(40px);
    }
    .reveal.fade-right {
      transform: translateX(-40px);
    }
    .reveal.fade-left {
      transform: translateX(40px);
    }
    .reveal.scale-in {
      transform: scale(0.92);
    }
    .reveal.visible {
      opacity: 1;
      transform: translateY(0) translateX(0) scale(1);
    }
    /* Staggered children */
    .reveal-stagger > * {
      opacity: 0;
      transform: translateY(24px);
      transition: opacity 0.6s ease, transform 0.6s ease;
    }
    .reveal-stagger.visible > * {
      opacity: 1;
      transform: translateY(0);
    }
    .reveal-stagger.visible > *:nth-child(1) { transition-delay: 0s; }
    .reveal-stagger.visible > *:nth-child(2) { transition-delay: 0.1s; }
    .reveal-stagger.visible > *:nth-child(3) { transition-delay: 0.2s; }
    .reveal-stagger.visible > *:nth-child(4) { transition-delay: 0.3s; }
    .reveal-stagger.visible > *:nth-child(5) { transition-delay: 0.4s; }
    .reveal-stagger.visible > *:nth-child(6) { transition-delay: 0.5s; }
    .reveal-stagger.visible > *:nth-child(7) { transition-delay: 0.6s; }

    #calligraphy-canvas {
      position: fixed;
      inset: 0;
      z-index: 0;
      pointer-events: none;
    }
    .page-content {
      position: relative;
      z-index: 1;
    }

    /* Asymmetric decorative rule */
    .rule-asymmetric {
      border: none;
      height: 1px;
      background: linear-gradient(to left, rgba(26, 26, 24, 0.15), rgba(26, 26, 24, 0.03) 80%, transparent);
    }
    .dark .rule-asymmetric {
      background: linear-gradient(to left, rgba(212, 212, 204, 0.12), rgba(212, 212, 204, 0.02) 80%, transparent);
    }
  </style>
</head>
<body class="antialiased">

  <!-- CALLIGRAPHY CANVAS -->
  <canvas id="calligraphy-canvas"></canvas>

  <div class="page-content">

  <!-- NAVIGATION -->
  <nav class="fixed top-6 left-1/2 -translate-x-1/2 z-50">
    <div class="bg-white/90 dark:bg-[#1e1e21]/90 backdrop-blur-md rounded-full px-6 sm:px-8 py-3 border border-black/[0.06] dark:border-white/[0.06] shadow-sm">
      <div class="flex items-center gap-6 sm:gap-8">
        <a href={base + "/9/"} class="flex items-center gap-2.5">
          <img src="/brand/aosus-icon.svg" alt="أسس" class="w-7 h-7" />
          <span class="font-semibold text-[var(--ink)] dark:text-[var(--charcoal-text)]">أسس</span>
        </a>
        <div class="hidden md:flex items-center gap-6 text-sm text-[var(--ink-light)] dark:text-[var(--charcoal-muted)]">
          <a href="#about" class="hover:text-[var(--ink)] dark:hover:text-white transition-colors">من نحن</a>
          <a href="#services" class="hover:text-[var(--ink)] dark:hover:text-white transition-colors">الخدمات</a>
          <a href="#contest" class="hover:text-[var(--ink)] dark:hover:text-white transition-colors">الجائزة</a>
          <a href="#timeline" class="hover:text-[var(--ink)] dark:hover:text-white transition-colors">تاريخنا</a>
          <a href="#projects" class="hover:text-[var(--ink)] dark:hover:text-white transition-colors">المشاريع</a>
          <a href="#support" class="hover:text-[var(--ink)] dark:hover:text-white transition-colors">ادعمنا</a>
        </div>
        <button id="theme-toggle" class="w-8 h-8 flex items-center justify-center text-[var(--ink-lighter)] dark:text-[var(--charcoal-muted)] hover:text-[var(--ink)] dark:hover:text-white transition-colors" aria-label="تبديل المظهر">
          <svg class="w-4 h-4 dark:hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z" /></svg>
          <svg class="w-4 h-4 hidden dark:block" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="4" /><path d="M12 2v2m0 16v2M4.93 4.93l1.41 1.41m11.32 11.32l1.41 1.41M2 12h2m16 0h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41" /></svg>
        </button>
        <button id="mobile-toggle" class="md:hidden w-8 h-8 flex items-center justify-center text-[var(--ink-lighter)] dark:text-[var(--charcoal-muted)]" aria-label="القائمة">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M3.75 9h16.5m-16.5 6h16.5" /></svg>
        </button>
      </div>
    </div>
    <!-- Mobile Menu -->
    <div id="mobile-menu" class="mobile-menu mt-2 bg-white/95 dark:bg-[#1e1e21]/95 backdrop-blur-md rounded-2xl border border-black/[0.06] dark:border-white/[0.06] shadow-lg overflow-hidden">
      <div class="flex flex-col p-4 text-sm text-[var(--ink-light)] dark:text-[var(--charcoal-muted)]">
        <a href="#about" class="py-2.5 hover:text-[var(--ink)] dark:hover:text-white transition-colors">من نحن</a>
        <a href="#services" class="py-2.5 hover:text-[var(--ink)] dark:hover:text-white transition-colors">الخدمات</a>
        <a href="#contest" class="py-2.5 hover:text-[var(--ink)] dark:hover:text-white transition-colors">الجائزة</a>
        <a href="#timeline" class="py-2.5 hover:text-[var(--ink)] dark:hover:text-white transition-colors">تاريخنا</a>
        <a href="#projects" class="py-2.5 hover:text-[var(--ink)] dark:hover:text-white transition-colors">المشاريع</a>
        <a href="#support" class="py-2.5 hover:text-[var(--ink)] dark:hover:text-white transition-colors">ادعمنا</a>
      </div>
    </div>
  </nav>

  <!-- HERO — asymmetric, right-aligned in RTL -->
  <section class="min-h-screen flex flex-col justify-center px-6 pt-32 pb-20">
    <div class="max-w-6xl mx-auto w-full">
      <div class="max-w-4xl">
        <h1 class="font-serif-ar text-6xl sm:text-7xl md:text-8xl lg:text-[8.5rem] xl:text-[10rem] leading-[1.05] font-bold text-[var(--ink)] dark:text-white mb-8 reveal fade-up">
          أكبر مجتمع عربي
          <br />
          <span class="text-[var(--ink-lighter)] dark:text-[var(--charcoal-muted)]">للبرمجيات الحرة</span>
        </h1>
        <p class="text-lg md:text-xl text-[var(--ink-light)] dark:text-[var(--charcoal-muted)] max-w-xl leading-relaxed mb-12 reveal fade-up">
          مجتمع غير ربحي أسسه مجموعة من التقنيين العرب بهدف نشر ثقافة المصادر المفتوحة والبرمجيات الحرة في العالم العربي
        </p>
        <div class="flex flex-col sm:flex-row items-start gap-4 mb-24 reveal fade-up">
          <a href="https://discourse.aosus.org" class="px-8 py-3.5 bg-[#008a2f] text-white rounded-full text-sm font-medium hover:bg-[#006b24] transition-colors">
            انضم للمجتمع
          </a>
          <a href="#about" class="px-8 py-3.5 border border-[var(--ink)]/15 dark:border-white/15 text-[var(--ink)] dark:text-[var(--charcoal-text)] rounded-full text-sm font-medium hover:border-[var(--ink)]/30 dark:hover:border-white/30 transition-colors">
            تعرّف علينا
          </a>
        </div>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-16 max-w-3xl reveal fade-up">
        <div>
          <div class="font-serif-ar text-4xl md:text-5xl font-bold text-[var(--ink)] dark:text-white">6,000<span class="text-[#008a2f]">+</span></div>
          <div class="text-sm text-[var(--ink-lighter)] dark:text-[var(--charcoal-muted)] mt-2">عضو</div>
        </div>
        <div>
          <div class="font-serif-ar text-4xl md:text-5xl font-bold text-[var(--ink)] dark:text-white">5,000<span class="text-[#008a2f]">+</span></div>
          <div class="text-sm text-[var(--ink-lighter)] dark:text-[var(--charcoal-muted)] mt-2">مشاركة</div>
        </div>
        <div>
          <div class="font-serif-ar text-4xl md:text-5xl font-bold text-[var(--ink)] dark:text-white">10</div>
          <div class="text-sm text-[var(--ink-lighter)] dark:text-[var(--charcoal-muted)] mt-2">سنوات</div>
        </div>
        <div>
          <div class="font-serif-ar text-4xl md:text-5xl font-bold text-[var(--ink)] dark:text-white">3,000<span class="text-[#008a2f]">+</span></div>
          <div class="text-sm text-[var(--ink-lighter)] dark:text-[var(--charcoal-muted)] mt-2">موضوع</div>
        </div>
      </div>
    </div>
  </section>

  <div class="rule-asymmetric max-w-6xl mx-auto"></div>

  <!-- ABOUT / من نحن -->
  <section id="about" class="py-24 md:py-36 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="grid md:grid-cols-[1.4fr,1fr] gap-16 md:gap-24 mb-20">
        <div>
          <h2 class="font-serif-ar text-5xl md:text-6xl lg:text-7xl font-bold text-[var(--ink)] dark:text-white mb-10 reveal fade-right">من نحن</h2>
          <div class="reveal fade-up">
            <h3 class="text-xs font-semibold tracking-widest text-[var(--ink-lighter)] dark:text-[var(--charcoal-muted)] uppercase mb-4">الرؤية</h3>
            <p class="text-lg leading-relaxed text-[var(--ink-light)] dark:text-[var(--charcoal-text)]">
              نشر الوعي بأهمية البرمجيات الحرة ومفتوحة المصدر في العالم العربي، وبناء مجتمع تقني عربي متميز يساهم في تطوير ودعم المشاريع مفتوحة المصدر.
            </p>
          </div>
        </div>
        <div class="flex flex-col justify-end reveal fade-left">
          <h3 class="text-xs font-semibold tracking-widest text-[var(--ink-lighter)] dark:text-[var(--charcoal-muted)] uppercase mb-4">المهمة</h3>
          <p class="text-lg leading-relaxed text-[var(--ink-light)] dark:text-[var(--charcoal-text)]">
            تقديم منصة متكاملة للنقاش والتعلم ومشاركة المعرفة حول البرمجيات الحرة والمفتوحة المصدر، وتوفير خدمات تحترم خصوصية المستخدمين.
          </p>
        </div>
      </div>

      <hr class="rule mb-16" />

      <h3 class="text-xs font-semibold tracking-widest text-[var(--ink-lighter)] dark:text-[var(--charcoal-muted)] uppercase mb-12 reveal fade-up">القيم</h3>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-16 reveal-stagger reveal fade-up">
        <div>
          <h4 class="font-serif-ar text-3xl font-bold text-[var(--ink)] dark:text-white mb-3">التعاون</h4>
          <p class="text-[var(--ink-light)] dark:text-[var(--charcoal-muted)] leading-relaxed">نؤمن بقوة العمل الجماعي والتعاون المفتوح بين أعضاء المجتمع</p>
        </div>
        <div>
          <h4 class="font-serif-ar text-3xl font-bold text-[var(--ink)] dark:text-white mb-3">الشفافية</h4>
          <p class="text-[var(--ink-light)] dark:text-[var(--charcoal-muted)] leading-relaxed">نلتزم بالشفافية الكاملة في جميع أعمالنا وقراراتنا</p>
        </div>
        <div>
          <h4 class="font-serif-ar text-3xl font-bold text-[var(--ink)] dark:text-white mb-3">الخصوصية</h4>
          <p class="text-[var(--ink-light)] dark:text-[var(--charcoal-muted)] leading-relaxed">نحترم خصوصية المستخدمين ونوفر بدائل تحمي بياناتهم</p>
        </div>
        <div>
          <h4 class="font-serif-ar text-3xl font-bold text-[var(--ink)] dark:text-white mb-3">المسؤولية</h4>
          <p class="text-[var(--ink-light)] dark:text-[var(--charcoal-muted)] leading-relaxed">نتحمل مسؤولية بناء مجتمع تقني عربي متميز ومستدام</p>
        </div>
      </div>
    </div>
  </section>

  <hr class="rule max-w-6xl mx-auto" />

  <!-- SERVICES / الخدمات -->
  <section id="services" class="py-24 md:py-36 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="grid md:grid-cols-[1fr,1.8fr] gap-16 md:gap-24">
        <div>
          <h2 class="font-serif-ar text-5xl md:text-6xl lg:text-7xl font-bold text-[var(--ink)] dark:text-white mb-6 reveal fade-right">الخدمات</h2>
          <p class="text-lg text-[var(--ink-light)] dark:text-[var(--charcoal-muted)] leading-relaxed reveal fade-up">
            نوفر مجموعة من الخدمات البديلة التي تحترم خصوصية المستخدمين وتعتمد على البرمجيات مفتوحة المصدر
          </p>
        </div>

        <div class="space-y-0 reveal fade-up">
          <a href="https://search.aosus.org" target="_blank" rel="noopener" class="group flex items-center justify-between py-5 border-b border-black/[0.06] dark:border-white/[0.06] hover:pr-4 transition-all">
            <div>
              <h3 class="text-lg font-medium text-[var(--ink)] dark:text-white group-hover:text-[#008a2f] transition-colors">SearXNG</h3>
              <p class="text-sm text-[var(--ink-lighter)] dark:text-[var(--charcoal-muted)]">محرك بحث يحترم الخصوصية</p>
            </div>
            <svg class="w-4 h-4 text-[var(--ink-lighter)] dark:text-[var(--charcoal-muted)] group-hover:text-[#008a2f] transition-colors -scale-x-100" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12h15m0 0l-6.75-6.75M19.5 12l-6.75 6.75" /></svg>
          </a>
          <a href="https://translate.aosus.org" target="_blank" rel="noopener" class="group flex items-center justify-between py-5 border-b border-black/[0.06] dark:border-white/[0.06] hover:pr-4 transition-all">
            <div>
              <h3 class="text-lg font-medium text-[var(--ink)] dark:text-white group-hover:text-[#008a2f] transition-colors">Simply Translate</h3>
              <p class="text-sm text-[var(--ink-lighter)] dark:text-[var(--charcoal-muted)]">ترجمة نصوص بدون تتبع</p>
            </div>
            <svg class="w-4 h-4 text-[var(--ink-lighter)] dark:text-[var(--charcoal-muted)] group-hover:text-[#008a2f] transition-colors -scale-x-100" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12h15m0 0l-6.75-6.75M19.5 12l-6.75 6.75" /></svg>
          </a>
          <a href="https://nitter.aosus.org" target="_blank" rel="noopener" class="group flex items-center justify-between py-5 border-b border-black/[0.06] dark:border-white/[0.06] hover:pr-4 transition-all">
            <div>
              <h3 class="text-lg font-medium text-[var(--ink)] dark:text-white group-hover:text-[#008a2f] transition-colors">Nitter</h3>
              <p class="text-sm text-[var(--ink-lighter)] dark:text-[var(--charcoal-muted)]">واجهة بديلة لتويتر</p>
            </div>
            <svg class="w-4 h-4 text-[var(--ink-lighter)] dark:text-[var(--charcoal-muted)] group-hover:text-[#008a2f] transition-colors -scale-x-100" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12h15m0 0l-6.75-6.75M19.5 12l-6.75 6.75" /></svg>
          </a>
          <a href="https://redlib.aosus.org" target="_blank" rel="noopener" class="group flex items-center justify-between py-5 border-b border-black/[0.06] dark:border-white/[0.06] hover:pr-4 transition-all">
            <div>
              <h3 class="text-lg font-medium text-[var(--ink)] dark:text-white group-hover:text-[#008a2f] transition-colors">Redlib</h3>
              <p class="text-sm text-[var(--ink-lighter)] dark:text-[var(--charcoal-muted)]">واجهة بديلة لريديت</p>
            </div>
            <svg class="w-4 h-4 text-[var(--ink-lighter)] dark:text-[var(--charcoal-muted)] group-hover:text-[#008a2f] transition-colors -scale-x-100" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12h15m0 0l-6.75-6.75M19.5 12l-6.75 6.75" /></svg>
          </a>
          <a href="https://element.aosus.org" target="_blank" rel="noopener" class="group flex items-center justify-between py-5 border-b border-black/[0.06] dark:border-white/[0.06] hover:pr-4 transition-all">
            <div>
              <h3 class="text-lg font-medium text-[var(--ink)] dark:text-white group-hover:text-[#008a2f] transition-colors">Element</h3>
              <p class="text-sm text-[var(--ink-lighter)] dark:text-[var(--charcoal-muted)]">تطبيق محادثة مشفر</p>
            </div>
            <svg class="w-4 h-4 text-[var(--ink-lighter)] dark:text-[var(--charcoal-muted)] group-hover:text-[#008a2f] transition-colors -scale-x-100" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12h15m0 0l-6.75-6.75M19.5 12l-6.75 6.75" /></svg>
          </a>
          <a href="https://rimgo.aosus.org" target="_blank" rel="noopener" class="group flex items-center justify-between py-5 border-b border-black/[0.06] dark:border-white/[0.06] hover:pr-4 transition-all">
            <div>
              <h3 class="text-lg font-medium text-[var(--ink)] dark:text-white group-hover:text-[#008a2f] transition-colors">rimgo</h3>
              <p class="text-sm text-[var(--ink-lighter)] dark:text-[var(--charcoal-muted)]">واجهة بديلة لإمجر</p>
            </div>
            <svg class="w-4 h-4 text-[var(--ink-lighter)] dark:text-[var(--charcoal-muted)] group-hover:text-[#008a2f] transition-colors -scale-x-100" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12h15m0 0l-6.75-6.75M19.5 12l-6.75 6.75" /></svg>
          </a>
          <a href="https://scribe.aosus.org" target="_blank" rel="noopener" class="group flex items-center justify-between py-5 border-b border-black/[0.06] dark:border-white/[0.06] hover:pr-4 transition-all">
            <div>
              <h3 class="text-lg font-medium text-[var(--ink)] dark:text-white group-hover:text-[#008a2f] transition-colors">Scribe</h3>
              <p class="text-sm text-[var(--ink-lighter)] dark:text-[var(--charcoal-muted)]">واجهة بديلة لميديم</p>
            </div>
            <svg class="w-4 h-4 text-[var(--ink-lighter)] dark:text-[var(--charcoal-muted)] group-hover:text-[#008a2f] transition-colors -scale-x-100" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12h15m0 0l-6.75-6.75M19.5 12l-6.75 6.75" /></svg>
          </a>
          <a href="https://quetre.aosus.org" target="_blank" rel="noopener" class="group flex items-center justify-between py-5 border-b border-black/[0.06] dark:border-white/[0.06] hover:pr-4 transition-all">
            <div>
              <h3 class="text-lg font-medium text-[var(--ink)] dark:text-white group-hover:text-[#008a2f] transition-colors">Quetre</h3>
              <p class="text-sm text-[var(--ink-lighter)] dark:text-[var(--charcoal-muted)]">واجهة بديلة لكورا</p>
            </div>
