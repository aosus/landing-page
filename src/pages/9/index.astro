  <script>
    // ===== Ink Wash Canvas Effect =====
    (function() {
      const canvas = document.getElementById('ink-canvas');
      const ctx = canvas.getContext('2d');

      function resize() {
        canvas.width = window.innerWidth;
        canvas.height = window.innerHeight;
      }
      resize();
      window.addEventListener('resize', resize);

      // Ink splatter particles
      class InkDrop {
        constructor(x, y) {
          this.x = x;
          this.y = y;
          this.radius = Math.random() * 60 + 20;
          this.opacity = 0.15 + Math.random() * 0.1;
          this.vx = (Math.random() - 0.5) * 4;
          this.vy = (Math.random() - 0.5) * 4;
          this.life = 1;
          this.decay = 0.008 + Math.random() * 0.008;
        }

        update() {
          this.x += this.vx;
          this.y += this.vy;
          this.radius += 0.8;
          this.life -= this.decay;
          this.vx *= 0.98;
          this.vy *= 0.98;
        }

        draw() {
          if (this.life <= 0) return;
          const isDark = document.documentElement.classList.contains('dark');
          const color = isDark ? '18, 18, 16' : '240, 235, 224';
          ctx.beginPath();
          ctx.arc(this.x, this.y, this.radius, 0, Math.PI * 2);
          ctx.fillStyle = `rgba(${color}, ${this.opacity * this.life})`;
          ctx.fill();
        }
      }

      let drops = [];
      let isAnimating = false;

      function triggerInkEffect(sectionEl) {
        const rect = sectionEl.getBoundingClientRect();
        const centerX = rect.left + rect.width / 2;
        const centerY = rect.top + rect.height / 2;

        // Create burst of ink drops
        for (let i = 0; i < 15; i++) {
          drops.push(new InkDrop(
            centerX + (Math.random() - 0.5) * rect.width * 0.8,
            centerY + (Math.random() - 0.5) * rect.height * 0.6
          ));
        }

        if (!isAnimating) {
          canvas.style.opacity = '1';
          isAnimating = true;
          animate();
        }
      }

      function animate() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);

        drops = drops.filter(d => d.life > 0);
        drops.forEach(d => {
          d.update();
          d.draw();
        });

        if (drops.length > 0) {
          requestAnimationFrame(animate);
        } else {
          canvas.style.opacity = '0';
          isAnimating = false;
        }
      }

      // Observe ink sections for scroll reveal
      const inkObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting && !entry.target.classList.contains('revealed')) {
            triggerInkEffect(entry.target);
            entry.target.classList.add('revealed');
          }
        });
      }, { threshold: 0.15, rootMargin: '0px 0px -60px 0px' });

      document.querySelectorAll('.ink-section').forEach(el => inkObserver.observe(el));

      // Also reveal first section immediately
      setTimeout(() => {
        const first = document.querySelector('.ink-section');
        if (first && !first.classList.contains('revealed')) {
          triggerInkEffect(first);
          first.classList.add('revealed');
        }
      }, 300);
    })();

    // ===== Theme Toggle =====
    const toggle = document.getElementById('theme-toggle');
    const html = document.documentElement;
    const moonIcon = toggle.querySelector('.theme-moon');
    const sunIcon = toggle.querySelector('.theme-sun');

    const savedTheme = localStorage.getItem('theme-9');
    const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;

    if (savedTheme === 'dark' || (!savedTheme && prefersDark)) {
      html.classList.add('dark');
      moonIcon.style.display = 'none';
      sunIcon.style.display = 'block';
    }

    toggle.addEventListener('click', () => {
      html.classList.toggle('dark');
      const isDark = html.classList.contains('dark');
      moonIcon.style.display = isDark ? 'none' : 'block';
      sunIcon.style.display = isDark ? 'block' : 'none';
      localStorage.setItem('theme-9', isDark ? 'dark' : 'light');
    });

    // ===== Mobile Menu =====
    const mobileToggle = document.getElementById('mobile-toggle');
    const mobileMenu = document.getElementById('mobile-menu');
    mobileToggle.addEventListener('click', () => {
      mobileMenu.classList.toggle('active');
    });
    mobileMenu.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => mobileMenu.classList.remove('active'));
    });
  </script>

</body>
</html>
