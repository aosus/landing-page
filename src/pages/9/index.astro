  </div><!-- .page-content -->

  <script>
    // ─── Theme toggle ───
    const toggle = document.getElementById('theme-toggle');
    const html = document.documentElement;
    if (localStorage.getItem('theme-9') === 'dark') html.classList.add('dark');
    toggle?.addEventListener('click', () => {
      html.classList.toggle('dark');
      localStorage.setItem('theme-9', html.classList.contains('dark') ? 'dark' : 'light');
      window.dispatchEvent(new CustomEvent('themechange'));
    });

    // ─── Mobile menu ───
    const mobileToggle = document.getElementById('mobile-toggle');
    const mobileMenu = document.getElementById('mobile-menu');
    mobileToggle?.addEventListener('click', () => mobileMenu?.classList.toggle('active'));
    mobileMenu?.querySelectorAll('a').forEach(a => a.addEventListener('click', () => mobileMenu?.classList.remove('active')));

    // ─── Reveal on scroll (with varied animation classes) ───
    const revealObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        }
      });
    }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });

    document.querySelectorAll('.reveal, .reveal-stagger').forEach(el => {
      // Add default fade-up if no specific animation class is set
      if (!el.classList.contains('fade-up') && !el.classList.contains('fade-right') && !el.classList.contains('fade-left') && !el.classList.contains('scale-in') && !el.classList.contains('reveal-stagger')) {
        el.classList.add('fade-up');
      }
      revealObserver.observe(el);
    });

    // ─── Arabic Calligraphy Canvas — scroll-based parallax ───
    (function() {
      const canvas = document.getElementById('calligraphy-canvas');
      if (!canvas) return;
      const ctx = canvas.getContext('2d');
      if (!ctx) return;

      let W = 0, H = 0;
      let scrollY = 0;
      let targetScrollY = 0;
      const isMobile = window.matchMedia('(max-width: 768px)').matches;

      function resize() {
        W = canvas.width = window.innerWidth;
        H = canvas.height = window.innerHeight;
      }
      resize();
      window.addEventListener('resize', () => {
        resize();
        strokes = createStrokes();
      });

      // Track scroll position
      window.addEventListener('scroll', () => {
        targetScrollY = window.scrollY;
      }, { passive: true });

      // Calligraphy stroke path templates
      const pathTemplates = [
        // Flowing horizontal baseline
        { type: 'cubic', points: [0, 0.5, 0.15, 0.35, 0.35, 0.65, 0.5, 0.5], lineWidth: 3 },
        // Ascending alef
        { type: 'cubic', points: [0.5, 0.8, 0.48, 0.5, 0.52, 0.3, 0.5, 0.1], lineWidth: 2.5 },
        // Sweeping baa
        { type: 'cubic', points: [0, 0.5, 0.2, 0.7, 0.4, 0.7, 0.6, 0.5], lineWidth: 3.5 },
        // Nun bowl
        { type: 'quadratic', points: [0.2, 0.4, 0.5, 0.7, 0.8, 0.4], lineWidth: 2 },
        // Lam descender
        { type: 'cubic', points: [0.5, 0.2, 0.45, 0.4, 0.55, 0.6, 0.5, 0.9], lineWidth: 2 },
        // Sin teeth
        { type: 'multi', segments: [
          { type: 'quadratic', points: [0, 0.5, 0.1, 0.3, 0.2, 0.5] },
          { type: 'quadratic', points: [0.2, 0.5, 0.3, 0.3, 0.4, 0.5] },
          { type: 'quadratic', points: [0.4, 0.5, 0.5, 0.3, 0.6, 0.5] },
        ], lineWidth: 1.5 },
        // Waw loop
        { type: 'cubic', points: [0.3, 0.3, 0.1, 0.3, 0.1, 0.7, 0.3, 0.7], lineWidth: 2 },
        // Ha figure-eight
        { type: 'multi', segments: [
          { type: 'cubic', points: [0.5, 0.3, 0.2, 0.3, 0.2, 0.6, 0.5, 0.5] },
          { type: 'cubic', points: [0.5, 0.5, 0.8, 0.4, 0.8, 0.7, 0.5, 0.7] },
        ], lineWidth: 2 },
        // Sweeping kaaf top
        { type: 'cubic', points: [0.1, 0.5, 0.3, 0.2, 0.6, 0.2, 0.9, 0.4], lineWidth: 3 },
        // Dot cluster
        { type: 'dots', points: [0.4, 0.4, 0.5, 0.35, 0.6, 0.4], radius: 3 },
        // Flowing ain curve
        { type: 'cubic', points: [0.2, 0.3, 0.1, 0.6, 0.5, 0.8, 0.8, 0.5], lineWidth: 2.5 },
        // Meem circle
        { type: 'cubic', points: [0.5, 0.3, 0.3, 0.3, 0.3, 0.7, 0.5, 0.7], lineWidth: 2 },
        // Long connecting stroke
        { type: 'cubic', points: [0, 0.5, 0.25, 0.45, 0.75, 0.55, 1, 0.5], lineWidth: 4 },
        // Taa curve with extension
        { type: 'multi', segments: [
          { type: 'cubic', points: [0.1, 0.5, 0.2, 0.3, 0.4, 0.3, 0.5, 0.5] },
          { type: 'quadratic', points: [0.5, 0.5, 0.7, 0.6, 0.9, 0.5] },
        ], lineWidth: 2.5 },
        // Yaa descender hook
        { type: 'cubic', points: [0.3, 0.3, 0.5, 0.5, 0.4, 0.8, 0.2, 0.9], lineWidth: 2 },
        // Daal simple curve
        { type: 'quadratic', points: [0.2, 0.3, 0.5, 0.3, 0.7, 0.6], lineWidth: 3 },
        // Raa swoop
        { type: 'cubic', points: [0.5, 0.3, 0.55, 0.5, 0.4, 0.7, 0.3, 0.8], lineWidth: 2 },
        // Single dot
        { type: 'dots', points: [0.5, 0.5], radius: 4 },
        // Sheen triple peak
        { type: 'multi', segments: [
          { type: 'quadratic', points: [0, 0.6, 0.1, 0.3, 0.2, 0.6] },
          { type: 'quadratic', points: [0.2, 0.6, 0.3, 0.3, 0.4, 0.6] },
          { type: 'quadratic', points: [0.4, 0.6, 0.5, 0.3, 0.6, 0.6] },
          { type: 'quadratic', points: [0.6, 0.6, 0.8, 0.7, 1, 0.6] },
        ], lineWidth: 1.5 },
        // Tail descender
        { type: 'quadratic', points: [0.5, 0.4, 0.6, 0.8, 0.4, 0.9], lineWidth: 1.5 },
      ];

      function createStrokes() {
        const strokes = [];
        const count = isMobile ? 12 : 20;
        for (let i = 0; i < count; i++) {
          const template = pathTemplates[i % pathTemplates.length];
          const scale = 100 + Math.random() * 300;
          strokes.push({
            template,
            x: Math.random() * W,
            y: Math.random() * H,
            scale,
            rotation: Math.random() * Math.PI * 2,
            parallaxFactor: 0.02 + Math.random() * 0.06,
            driftFactor: 0.005 + Math.random() * 0.02,
            lineWidth: template.lineWidth || 2,
          });
        }
        return strokes;
      }

      let strokes = createStrokes();

      function isDark() {
        return document.documentElement.classList.contains('dark');
      }

      function getStrokeColor() {
        return isDark()
          ? 'rgba(212, 212, 204, 0.035)'
          : 'rgba(26, 26, 24, 0.035)';
      }

      function getDotColor() {
        return isDark()
          ? 'rgba(212, 212, 204, 0.03)'
          : 'rgba(26, 26, 24, 0.03)';
      }

      function drawStroke(stroke) {
        const { template, x, y, scale, rotation, parallaxFactor, driftFactor, lineWidth } = stroke;
        const verticalShift = scrollY * parallaxFactor;
        const horizontalDrift = Math.sin(scrollY * 0.001 + x * 0.001) * scrollY * driftFactor * 0.1;

        ctx.save();
        ctx.translate(x + horizontalDrift, y - verticalShift);
        ctx.rotate(rotation);

        if (template.type === 'dots') {
          ctx.fillStyle = getDotColor();
          const pts = template.points;
          for (let i = 0; i < pts.length; i += 2) {
            ctx.beginPath();
            ctx.arc(
              (pts[i] - 0.5) * scale,
              (pts[i + 1] - 0.5) * scale,
              template.radius || 3,
              0,
              Math.PI * 2
            );
            ctx.fill();
          }
        } else {
          ctx.strokeStyle = getStrokeColor();
          ctx.lineWidth = lineWidth;
          ctx.lineCap = 'round';
          ctx.lineJoin = 'round';
          ctx.beginPath();

          if (template.type === 'cubic') {
            const p = template.points;
            ctx.moveTo((p[0] - 0.5) * scale, (p[1] - 0.5) * scale);
            ctx.bezierCurveTo(
              (p[2] - 0.5) * scale, (p[3] - 0.5) * scale,
              (p[4] - 0.5) * scale, (p[5] - 0.5) * scale,
              (p[6] - 0.5) * scale, (p[7] - 0.5) * scale
            );
          } else if (template.type === 'quadratic') {
            const p = template.points;
            ctx.moveTo((p[0] - 0.5) * scale, (p[1] - 0.5) * scale);
            ctx.quadraticCurveTo(
              (p[2] - 0.5) * scale, (p[3] - 0.5) * scale,
              (p[4] - 0.5) * scale, (p[5] - 0.5) * scale
            );
          } else if (template.type === 'multi') {
            const segs = template.segments;
            const firstSeg = segs[0];
            ctx.moveTo(
              (firstSeg.points[0] - 0.5) * scale,
              (firstSeg.points[1] - 0.5) * scale
            );
            for (const seg of segs) {
              if (seg.type === 'cubic') {
                const p = seg.points;
                ctx.bezierCurveTo(
                  (p[2] - 0.5) * scale, (p[3] - 0.5) * scale,
                  (p[4] - 0.5) * scale, (p[5] - 0.5) * scale,
                  (p[6] - 0.5) * scale, (p[7] - 0.5) * scale
                );
              } else {
                const p = seg.points;
                ctx.quadraticCurveTo(
                  (p[2] - 0.5) * scale, (p[3] - 0.5) * scale,
                  (p[4] - 0.5) * scale, (p[5] - 0.5) * scale
                );
              }
            }
          }
          ctx.stroke();
        }
        ctx.restore();
      }

      function animate() {
        // Smooth scroll interpolation
        scrollY += (targetScrollY - scrollY) * 0.08;

        ctx.clearRect(0, 0, W, H);
        for (const stroke of strokes) {
          drawStroke(stroke);
        }
        requestAnimationFrame(animate);
      }

      animate();
    })();
  </script>
