  <script>
    // ===== THEME TOGGLE =====
    const toggle = document.getElementById('theme-toggle');
    const html = document.documentElement;
    const body = document.body;
    const moonIcon = toggle.querySelector('.icon-moon');
    const sunIcon = toggle.querySelector('.icon-sun');

    // Default dark, toggle to light
    const savedTheme = localStorage.getItem('theme-7');
    if (savedTheme === 'light') {
      html.classList.add('light');
      body.classList.add('light');
      moonIcon.style.display = 'block';
      sunIcon.style.display = 'none';
    }

    toggle.addEventListener('click', () => {
      const isLight = html.classList.toggle('light');
      body.classList.toggle('light');
      moonIcon.style.display = isLight ? 'block' : 'none';
      sunIcon.style.display = isLight ? 'none' : 'block';
      localStorage.setItem('theme-7', isLight ? 'light' : 'dark');
    });

    // ===== MOBILE MENU =====
    const mobileToggle = document.getElementById('mobile-toggle');
    const mobileMenu = document.getElementById('mobile-menu');
    mobileToggle.addEventListener('click', () => mobileMenu.classList.toggle('active'));
    mobileMenu.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => mobileMenu.classList.remove('active'));
    });

    // ===== REVEAL ON SCROLL =====
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) entry.target.classList.add('visible');
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

    // ===== CALLIGRAPHY CANVAS =====
    const canvas = document.getElementById('calligraphy-canvas');
    const ctx = canvas.getContext('2d');
    let strokes = [];
    let animFrame;

    // Arabic calligraphy stroke paths — bezier curves that look like Arabic letterforms
    function generateStrokes() {
      const w = canvas.width / (window.devicePixelRatio || 1);
      const h = canvas.height / (window.devicePixelRatio || 1);
      strokes = [];

      const strokeCount = 8;
      for (let i = 0; i < strokeCount; i++) {
        const startX = Math.random() * w;
        const startY = Math.random() * h;
        const points = [];
        let cx = startX, cy = startY;

        // Each stroke has 3-5 bezier segments
        const segments = 3 + Math.floor(Math.random() * 3);
        for (let j = 0; j < segments; j++) {
          const dx = (Math.random() - 0.5) * 200;
          const dy = (Math.random() - 0.5) * 120;
          const cp1x = cx + (Math.random() - 0.5) * 150;
          const cp1y = cy + (Math.random() - 0.5) * 100;
          const cp2x = cx + dx + (Math.random() - 0.5) * 150;
          const cp2y = cy + dy + (Math.random() - 0.5) * 100;
          const ex = cx + dx;
          const ey = cy + dy;
          points.push({ cp1x, cp1y, cp2x, cp2y, ex, ey });
          cx = ex;
          cy = ey;
        }

        strokes.push({
          startX, startY,
          points,
          progress: Math.random(), // start at random progress
          speed: 0.001 + Math.random() * 0.002,
          lineWidth: 1 + Math.random() * 2,
          opacity: 0.03 + Math.random() * 0.04,
          direction: Math.random() > 0.5 ? 1 : -1,
        });
      }
    }

    function initCalligraphyCanvas() {
      const rect = canvas.parentElement.getBoundingClientRect();
      const dpr = window.devicePixelRatio || 1;
      canvas.width = rect.width * dpr;
      canvas.height = rect.height * dpr;
      canvas.style.width = rect.width + 'px';
      canvas.style.height = rect.height + 'px';
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      generateStrokes();
    }

    function drawCalligraphy() {
      const w = canvas.width / (window.devicePixelRatio || 1);
      const h = canvas.height / (window.devicePixelRatio || 1);
      ctx.clearRect(0, 0, w, h);

      const isLight = html.classList.contains('light');
      const strokeColor = isLight ? '26, 26, 24' : '0, 166, 58';

      for (const stroke of strokes) {
        stroke.progress += stroke.speed * stroke.direction;
        if (stroke.progress >= 1) { stroke.progress = 1; stroke.direction = -1; }
        if (stroke.progress <= 0) { stroke.progress = 0; stroke.direction = 1; }

        const totalSegments = stroke.points.length;
        const drawnSegments = stroke.progress * totalSegments;

        ctx.beginPath();
        ctx.moveTo(stroke.startX, stroke.startY);

        for (let i = 0; i < totalSegments; i++) {
          const p = stroke.points[i];
          if (i < Math.floor(drawnSegments)) {
            ctx.bezierCurveTo(p.cp1x, p.cp1y, p.cp2x, p.cp2y, p.ex, p.ey);
          } else if (i === Math.floor(drawnSegments)) {
            const frac = drawnSegments - Math.floor(drawnSegments);
            // Partial segment — approximate with lerp
            const prevX = i === 0 ? stroke.startX : stroke.points[i-1].ex;
            const prevY = i === 0 ? stroke.startY : stroke.points[i-1].ey;
            const partialX = prevX + (p.ex - prevX) * frac;
            const partialY = prevY + (p.ey - prevY) * frac;
            const pcp1x = prevX + (p.cp1x - prevX) * frac;
            const pcp1y = prevY + (p.cp1y - prevY) * frac;
            ctx.bezierCurveTo(pcp1x, pcp1y, partialX, partialY, partialX, partialY);
          }
        }

        ctx.strokeStyle = `rgba(${strokeColor}, ${stroke.opacity})`;
        ctx.lineWidth = stroke.lineWidth;
        ctx.lineCap = 'round';
        ctx.lineJoin = 'round';
        ctx.stroke();
      }

      animFrame = requestAnimationFrame(drawCalligraphy);
    }

    window.addEventListener('resize', () => {
      cancelAnimationFrame(animFrame);
      initCalligraphyCanvas();
      drawCalligraphy();
    });

    initCalligraphyCanvas();
    drawCalligraphy();
  </script>

