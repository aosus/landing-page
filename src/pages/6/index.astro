---
import '../../styles/global.css';
const base = import.meta.env.GITHUB_ACTIONS ? '/landing-page' : '';
---

<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="أسس - أكبر مجتمع عربي للبرمجيات الحرة والمفتوحة المصدر" />
  <title>أسس - مجتمع البرمجيات الحرة والمفتوحة المصدر</title>
  <link rel="icon" type="image/svg+xml" href="/brand/aosus-icon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Amiri:wght@400;700&family=IBM+Plex+Sans+Arabic:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    :root {
      --cream: #FAF8F5;
      --cream-dark: #EAE6DF;
      --ink: #232220;
      --ink-light: #5A5752;
      --ink-lighter: #8A8780;
      --charcoal: #141312;
      --charcoal-light: #1E1C1B;
      --charcoal-text: #E3E1DB;
      --charcoal-muted: #95928B;
      --primary: #008a2f;
      --primary-hover: #006b24;
    }
    
    body {
      font-family: 'IBM Plex Sans Arabic', sans-serif;
      background: var(--cream);
      color: var(--ink);
      overflow-x: hidden;
    }
    
    .dark body {
      background: var(--charcoal);
      color: var(--charcoal-text);
    }
    
    .font-serif-ar {
      font-family: 'Amiri', serif;
    }
    
    /* Dynamic Reactive Background */
    #dynamic-bg {
      position: fixed;
      top: 0;
      left: 0;
      width: 100vw;
      height: 100vh;
      pointer-events: none;
      z-index: 0;
      background: radial-gradient(800px circle at var(--mouse-x, 50%) var(--mouse-y, 50%), rgba(0, 138, 47, 0.04), transparent 40%);
      transition: background 0.5s ease;
      will-change: background;
    }
    .dark #dynamic-bg {
      background: radial-gradient(800px circle at var(--mouse-x, 50%) var(--mouse-y, 50%), rgba(255, 255, 255, 0.02), transparent 40%);
    }

    /* Modern Minimal Rule */
    .rule {
      border: none;
      height: 1px;
      background: linear-gradient(90deg, transparent, rgba(35, 34, 32, 0.1), transparent);
    }
    .dark .rule {
      background: linear-gradient(90deg, transparent, rgba(227, 225, 219, 0.1), transparent);
    }
    
    /* Elegant Reveal with Blur */
    .reveal {
      opacity: 0;
      transform: translateY(24px);
      filter: blur(8px);
      transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), 
                  transform 0.8s cubic-bezier(0.16, 1, 0.3, 1), 
                  filter 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .reveal.visible {
      opacity: 1;
      transform: translateY(0);
      filter: blur(0);
    }

    /* Sophisticated Hover Effects */
    .classy-hover {
      transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .classy-hover:hover {
      transform: translateY(-6px);
    }
    .light-shadow-hover {
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.02);
    }
    .light-shadow-hover:hover {
      box-shadow: 0 20px 40px rgba(0, 0, 0, 0.06);
    }
    .dark-shadow-hover {
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
    }
    .dark .dark-shadow-hover:hover {
      box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
    }

    /* Dynamic Text Gradient */
    .text-gradient {
      background: linear-gradient(to left, var(--primary), #10b981);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .dark .text-gradient {
      background: linear-gradient(to left, #4ade80, #34d399);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    /* Smooth scroll */
    html { scroll-behavior: smooth; }
    
    /* Mobile menu */
    .mobile-menu { display: none; }
    .mobile-menu.active { display: block; }
  </style>
</head>
<body class="antialiased relative selection:bg-[var(--primary)] selection:text-white">

  <!-- Reactive Background Layer -->
  <div id="dynamic-bg"></div>

  <!-- Main Content Wrapper to sit above the dynamic background -->
  <div class="relative z-10">

    <!-- NAVIGATION -->
    <nav class="fixed top-6 left-1/2 -translate-x-1/2 z-50 w-[90%] max-w-4xl transition-all duration-300">
      <div class="bg-white/70 dark:bg-[#1E1C1B]/70 backdrop-blur-xl rounded-full px-6 py-3 border border-black/5 dark:border-white/5 shadow-[0_8px_30px_rgb(0,0,0,0.04)] dark:shadow-[0_8px_30px_rgb(0,0,0,0.2)] hover:shadow-[0_12px_40px_rgb(0,0,0,0.08)] transition-shadow duration-500">
        <div class="flex items-center justify-between gap-8">
          <a href={base + "/6/"} class="flex items-center gap-2.5 group">
            <img src="/brand/aosus-icon.svg" alt="أسس" class="w-7 h-7 group-hover:scale-110 group-hover:rotate-3 transition-transform duration-500" />
            <span class="font-semibold text-[var(--ink)] dark:text-[var(--charcoal-text)] group-hover:text-[var(--primary)] transition-colors">أسس</span>
          </a>
          <div class="hidden md:flex items-center gap-6 text-sm font-medium text-[var(--ink-light)] dark:text-[var(--charcoal-muted)]">
            <a href="#about" class="relative py-1 group hover:text-[var(--ink)] dark:hover:text-white transition-colors">
              من نحن
              <span class="absolute bottom-0 right-0 w-full h-[2px] bg-[var(--primary)] scale-x-0 group-hover:scale-x-100 transition-transform origin-right duration-300"></span>
            </a>
            <a href="#services" class="relative py-1 group hover:text-[var(--ink)] dark:hover:text-white transition-colors">
              الخدمات
              <span class="absolute bottom-0 right-0 w-full h-[2px] bg-[var(--primary)] scale-x-0 group-hover:scale-x-100 transition-transform origin-right duration-300"></span>
            </a>
            <a href="#contest" class="relative py-1 group hover:text-[var(--ink)] dark:hover:text-white transition-colors">
              الجائزة
              <span class="absolute bottom-0 right-0 w-full h-[2px] bg-[var(--primary)] scale-x-0 group-hover:scale-x-100 transition-transform origin-right duration-300"></span>
            </a>
            <a href="#timeline" class="relative py-1 group hover:text-[var(--ink)] dark:hover:text-white transition-colors">
              تاريخنا
              <span class="absolute bottom-0 right-0 w-full h-[2px] bg-[var(--primary)] scale-x-0 group-hover:scale-x-100 transition-transform origin-right duration-300"></span>
            </a>
            <a href="#projects" class="relative py-1 group hover:text-[var(--ink)] dark:hover:text-white transition-colors">
              المشاريع
              <span class="absolute bottom-0 right-0 w-full h-[2px] bg-[var(--primary)] scale-x-0 group-hover:scale-x-100 transition-transform origin-right duration-300"></span>
            </a>
            <a href="#support" class="relative py-1 group hover:text-[var(--ink)] dark:hover:text-white transition-colors">
              ادعمنا
              <span class="absolute bottom-0 right-0 w-full h-[2px] bg-[var(--primary)] scale-x-0 group-hover:scale-x-100 transition-transform origin-right duration-300"></span>
            </a>
          </div>
          <div class="flex items-center gap-2">
            <button id="theme-toggle" class="w-9 h-9 flex items-center justify-center rounded-full bg-black/5 dark:bg-white/5 text-[var(--ink-light)] dark:text-[var(--charcoal-muted)] hover:text-[var(--ink)] dark:hover:text-white hover:scale-110 transition-all duration-300" aria-label="تبديل المظهر">
              <svg class="w-4 h-4 dark:hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z" /></svg>
              <svg class="w-4 h-4 hidden dark:block" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="4" /><path d="M12 2v2m0 16v2M4.93 4.93l1.41 1.41m11.32 11.32l1.41 1.41M2 12h2m16 0h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41" /></svg>
            </button>
            <button id="mobile-toggle" class="md:hidden w-9 h-9 flex items-center justify-center rounded-full bg-black/5 dark:bg-white/5 text-[var(--ink-light)] dark:text-[var(--charcoal-muted)]" aria-label="القائمة">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M3.75 9h16.5m-16.5 6h16.5" /></svg>
            </button>
          </div>
        </div>
      </div>
      <!-- Mobile Menu -->
      <div id="mobile-menu" class="mobile-menu mt-3 bg-white/90 dark:bg-[#1E1C1B]/90 backdrop-blur-xl rounded-2xl border border-black/5 dark:border-white/5 shadow-2xl overflow-hidden transform origin-top transition-all">
        <div class="flex flex-col p-4 text-sm font-medium text-[var(--ink-light)] dark:text-[var(--charcoal-muted)]">
          <a href="#about" class="px-4 py-3 rounded-lg hover:bg-black/5 dark:hover:bg-white/5 hover:text-[var(--ink)] dark:hover:text-white transition-colors">من نحن</a>
          <a href="#services" class="px-4 py-3 rounded-lg hover:bg-black/5 dark:hover:bg-white/5 hover:text-[var(--ink)] dark:hover:text-white transition-colors">الخدمات</a>
          <a href="#contest" class="px-4 py-3 rounded-lg hover:bg-black/5 dark:hover:bg-white/5 hover:text-[var(--ink)] dark:hover:text-white transition-colors">الجائزة</a>
          <a href="#timeline" class="px-4 py-3 rounded-lg hover:bg-black/5 dark:hover:bg-white/5 hover:text-[var(--ink)] dark:hover:text-white transition-colors">تاريخنا</a>
          <a href="#projects" class="px-4 py-3 rounded-lg hover:bg-black/5 dark:hover:bg-white/5 hover:text-[var(--ink)] dark:hover:text-white transition-colors">المشاريع</a>
          <a href="#support" class="px-4 py-3 rounded-lg hover:bg-black/5 dark:hover:bg-white/5 hover:text-[var(--ink)] dark:hover:text-white transition-colors">ادعمنا</a>
        </div>
      </div>
    </nav>

    <!-- HERO -->
    <section class="min-h-screen flex flex-col items-center justify-center px-6 pt-32 pb-20 relative overflow-hidden">
      <!-- Subtle decorative element -->
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-[var(--primary)]/5 rounded-full blur-[100px] -z-10 animate-pulse" style="animation-duration: 8s;"></div>
      
      <div class="max-w-5xl mx-auto text-center relative z-10">
        <h1 class="font-serif-ar text-6xl sm:text-7xl md:text-8xl lg:text-[9rem] leading-[1.1] font-bold text-[var(--ink)] dark:text-white mb-8 reveal">
          أكبر مجتمع عربي
          <br />
          <span class="text-gradient drop-shadow-sm">للبرمجيات الحرة</span>
        </h1>
        <p class="text-lg md:text-2xl text-[var(--ink-light)] dark:text-[var(--charcoal-muted)] max-w-2xl mx-auto leading-relaxed mb-12 reveal" style="transition-delay: 100ms;">
          مجتمع غير ربحي أسسه مجموعة من التقنيين العرب بهدف نشر ثقافة المصادر المفتوحة والبرمجيات الحرة في العالم العربي
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-5 mb-24 reveal" style="transition-delay: 200ms;">
          <a href="https://discourse.aosus.org" class="group relative px-8 py-4 bg-[var(--primary)] text-white rounded-full text-base font-semibold hover:bg-[var(--primary-hover)] hover:-translate-y-1 hover:shadow-[0_12px_30px_rgba(0,138,47,0.3)] transition-all overflow-hidden">
            <span class="relative z-10">انضم للمجتمع</span>
            <div class="absolute inset-0 bg-white/20 translate-y-full group-hover:translate-y-0 transition-transform duration-300 ease-out"></div>
          </a>
          <a href="#about" class="px-8 py-4 border border-[var(--ink)]/15 dark:border-white/15 text-[var(--ink)] dark:text-[var(--charcoal-text)] rounded-full text-base font-medium hover:border-[var(--ink)]/40 dark:hover:border-white/40 hover:-translate-y-1 hover:bg-black/5 dark:hover:bg-white/5 transition-all">
            تعرّف علينا
          </a>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-16 reveal" style="transition-delay: 300ms;">
          <div class="text-center group p-6 rounded-3xl bg-white/30 dark:bg-white/5 border border-white/40 dark:border-white/5 backdrop-blur-md classy-hover light-shadow-hover dark:dark-shadow-hover">
            <div class="font-serif-ar text-4xl md:text-5xl font-bold text-[var(--ink)] dark:text-white group-hover:scale-110 transition-transform duration-500 group-hover:text-[var(--primary)]">6000<span class="text-[var(--primary)]">+</span></div>
            <div class="text-sm font-medium text-[var(--ink-lighter)] dark:text-[var(--charcoal-muted)] mt-2">عضو</div>
          </div>
          <div class="text-center group p-6 rounded-3xl bg-white/30 dark:bg-white/5 border border-white/40 dark:border-white/5 backdrop-blur-md classy-hover light-shadow-hover dark:dark-shadow-hover">
            <div class="font-serif-ar text-4xl md:text-5xl font-bold text-[var(--ink)] dark:text-white group-hover:scale-110 transition-transform duration-500 group-hover:text-[var(--primary)]">5000<span class="text-[var(--primary)]">+</span></div>
            <div class="text-sm font-medium text-[var(--ink-lighter)] dark:text-[var(--charcoal-muted)] mt-2">مشاركة</div>
          </div>
          <div class="text-center group p-6 rounded-3xl bg-white/30 dark:bg-white/5 border border-white/40 dark:border-white/5 backdrop-blur-md classy-hover light-shadow-hover dark:dark-shadow-hover">
            <div class="font-serif-ar text-4xl md:text-5xl font-bold text-[var(--ink)] dark:text-white group-hover:scale-110 transition-transform duration-500 group-hover:text-[var(--primary)]">10</div>
            <div class="text-sm font-medium text-[var(--ink-lighter)] dark:text-[var(--charcoal-muted)] mt-2">سنوات</div>
          </div>
          <div class="text-center group p-6 rounded-3xl bg-white/30 dark:bg-white/5 border border-white/40 dark:border-white/5 backdrop-blur-md classy-hover light-shadow-hover dark:dark-shadow-hover">
            <div class="font-serif-ar text-4xl md:text-5xl font-bold text-[var(--ink)] dark:text-white group-hover:scale-110 transition-transform duration-500 group-hover:text-[var(--primary)]">3000<span class="text-[var(--primary)]">+</span></div>
            <div class="text-sm font-medium text-[var(--ink-lighter)] dark:text-[var(--charcoal-muted)] mt-2">موضوع</div>
          </div>
        </div>
      </div>
    </section>

    <hr class="rule max-w-5xl mx-auto" />

    <!-- ABOUT / من نحن -->
    <section id="about" class="py-24 md:py-32 px-6 relative">
      <div class="max-w-5xl mx-auto">
        <h2 class="font-serif-ar text-5xl md:text-6xl lg:text-7xl font-bold text-[var(--ink)] dark:text-white mb-16 reveal">من نحن</h2>

        <div class="grid md:grid-cols-2 gap-8 mb-24">
          <div class="reveal p-8 rounded-3xl bg-white/40 dark:bg-white/5 border border-white/60 dark:border-white/10 backdrop-blur-md classy-hover light-shadow-hover dark:dark-shadow-hover">
            <div class="w-12 h-12 rounded-full bg-[var(--primary)]/10 flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-[var(--primary)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg>
            </div>
            <h3 class="font-serif-ar text-3xl font-bold text-[var(--ink)] dark:text-white mb-4">الرؤية</h3>
            <p class="text-lg leading-relaxed text-[var(--ink-light)] dark:text-[var(--charcoal-text)]">
              نشر الوعي بأهمية البرمجيات الحرة ومفتوحة المصدر في العالم العربي، وبناء مجتمع تقني عربي متميز يساهم في تطوير ودعم المشاريع مفتوحة المصدر.
            </p>
          </div>
          <div class="reveal p-8 rounded-3xl bg-white/40 dark:bg-white/5 border border-white/60 dark:border-white/10 backdrop-blur-md classy-hover light-shadow-hover dark:dark-shadow-hover" style="transition-delay: 100ms;">
            <div class="w-12 h-12 rounded-full bg-[var(--primary)]/10 flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-[var(--primary)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
            </div>
            <h3 class="font-serif-ar text-3xl font-bold text-[var(--ink)] dark:text-white mb-4">المهمة</h3>
            <p class="text-lg leading-relaxed text-[var(--ink-light)] dark:text-[var(--charcoal-text)]">
              تقديم منصة متكاملة للنقاش والتعلم ومشاركة المعرفة حول البرمجيات الحرة والمفتوحة المصدر، وتوفير خدمات تحترم خصوصية المستخدمين.
            </p>
          </div>
        </div>

        <h3 class="font-serif-ar text-4xl font-bold text-[var(--ink)] dark:text-white mb-10 reveal">القيم</h3>
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6 reveal">
          <div class="p-8 rounded-3xl bg-white/30 dark:bg-white/5 border border-white/40 dark:border-white/10 backdrop-blur-md classy-hover light-shadow-hover dark:dark-shadow-hover group">
            <h4 class="font-serif-ar text-2xl font-bold text-[var(--ink)] dark:text-white mb-3 group-hover:text-[var(--primary)] transition-colors">التعاون</h4>
            <p class="text-[var(--ink-light)] dark:text-[var(--charcoal-muted)] leading-relaxed text-sm">نؤمن بقوة العمل الجماعي والتعاون المفتوح بين أعضاء المجتمع</p>
          </div>
          <div class="p-8 rounded-3xl bg-white/30 dark:bg-white/5 border border-white/40 dark:border-white/10 backdrop-blur-md classy-hover light-shadow-hover dark:dark-shadow-hover group" style="transition-delay: 100ms;">
            <h4 class="font-serif-ar text-2xl font-bold text-[var(--ink)] dark:text-white mb-3 group-hover:text-[var(--primary)] transition-colors">الشفافية</h4>
            <p class="text-[var(--ink-light)] dark:text-[var(--charcoal-muted)] leading-relaxed text-sm">نلتزم بالشفافية الكاملة في جميع أعمالنا وقراراتنا</p>
          </div>
          <div class="p-8 rounded-3xl bg-white/30 dark:bg-white/5 border border-white/40 dark:border-white/10 backdrop-blur-md classy-hover light-shadow-hover dark:dark-shadow-hover group" style="transition-delay: 200ms;">
            <h4 class="font-serif-ar text-2xl font-bold text-[var(--ink)] dark:text-white mb-3 group-hover:text-[var(--primary)] transition-colors">الخصوصية</h4>
            <p class="text-[var(--ink-light)] dark:text-[var(--charcoal-muted)] leading-relaxed text-sm">نحترم خصوصية المستخدمين ونوفر بدائل تحمي بياناتهم</p>
          </div>
          <div class="p-8 rounded-3xl bg-white/30 dark:bg-white/5 border border-white/40 dark:border-white/10 backdrop-blur-md classy-hover light-shadow-hover dark:dark-shadow-hover group" style="transition-delay: 300ms;">
            <h4 class="font-serif-ar text-2xl font-bold text-[var(--ink)] dark:text-white mb-3 group-hover:text-[var(--primary)] transition-colors">المسؤولية</h4>
            <p class="text-[var(--ink-light)] dark:text-[var(--charcoal-muted)] leading-relaxed text-sm">نتحمل مسؤولية بناء مجتمع تقني عربي متميز ومستدام</p>
          </div>
        </div>
      </div>
    </section>

    <hr class="rule max-w-5xl mx-auto" />

    <!-- SERVICES / الخدمات -->
    <section id="services" class="py-24 md:py-32 px-6">
      <div class="max-w-4xl mx-auto">
        <h2 class="font-serif-ar text-5xl md:text-6xl lg:text-7xl font-bold text-[var(--ink)] dark:text-white mb-6 reveal">الخدمات</h2>
        <p class="text-xl text-[var(--ink-light)] dark:text-[var(--charcoal-muted)] mb-16 max-w-2xl reveal">
          نوفر مجموعة من الخدمات البديلة التي تحترم خصوصية المستخدمين وتعتمد على البرمجيات مفتوحة المصدر
        </p>

        <div class="grid md:grid-cols-2 gap-4 reveal">
          <!-- Service Items -->
          <a href="https://search.aosus.org" target="_blank" rel="noopener" class="group flex items-center justify-between p-6 rounded-3xl bg-white/40 dark:bg-white/5 border border-white/60 dark:border-white/10 backdrop-blur-md classy-hover light-shadow-hover dark:dark-shadow-hover transition-all">
            <div>
              <h3 class="font-serif-ar text-2xl font-bold text-[var(--ink)] dark:text-white group-hover:text-[var(--primary)] transition-colors">SearXNG</h3>
              <p class="text-sm text-[var(--ink-light)] dark:text-[var(--charcoal-muted)] mt-1">محرك بحث يحترم الخصوصية</p>
            </div>
            <div class="w-12 h-12 rounded-full bg-black/5 dark:bg-white/5 flex items-center justify-center group-hover:bg-[var(--primary)] group-hover:text-white group-hover:scale-110 transition-all duration-300">
              <svg class="w-5 h-5 -scale-x-100" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12h15m0 0l-6.75-6.75M19.5 12l-6.75 6.75" /></svg>
            </div>
          </a>
          <a href="https://translate.aosus.org" target="_blank" rel="noopener" class="group flex items-center justify-between p-6 rounded-3xl bg-white/40 dark:bg-white/5 border border-white/60 dark:border-white/10 backdrop-blur-md classy-hover light-shadow-hover dark:dark-shadow-hover transition-all">
