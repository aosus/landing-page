---
import '../../styles/global.css';
const base = import.meta.env.GITHUB_ACTIONS ? '/landing-page' : '';
---

<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="أسس - أكبر مجتمع عربي للبرمجيات الحرة والمفتوحة المصدر" />
  <title>أسس - مجتمع البرمجيات الحرة والمفتوحة المصدر</title>
  <link rel="icon" type="image/svg+xml" href="/brand/aosus-icon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=IBM+Plex+Sans+Arabic:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    :root {
      --bg: #f5f5f0;
      --bg-alt: #eceae4;
      --text: #0a0a0a;
      --text-secondary: #555555;
      --text-tertiary: #888888;
      --border: #d4d4cc;
      --border-light: #e0e0d8;
      --green: #008a2f;
      --green-hover: #006b24;
      --blue: #1d70ba;
      --particle-color: 10, 10, 10;
      --particle-opacity: 0.12;
      --particle-accent-opacity: 0.18;
      --nav-bg: rgba(245, 245, 240, 0.85);
    }
    .dark {
      --bg: #0c0c0c;
      --bg-alt: #111111;
      --text: #ededed;
      --text-secondary: #a0a0a0;
      --text-tertiary: #606060;
      --border: #222222;
      --border-light: #1a1a1a;
      --green: #00a63a;
      --green-hover: #00c445;
      --blue: #4a9ede;
      --particle-color: 245, 243, 235;
      --particle-opacity: 0.18;
      --particle-accent-opacity: 0.25;
      --nav-bg: rgba(12, 12, 12, 0.85);
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'IBM Plex Sans Arabic', sans-serif;
      background: var(--bg);
      color: var(--text);
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
      overflow-x: hidden;
    }
    a { text-decoration: none; color: inherit; }
    .mono { font-family: 'IBM Plex Mono', monospace; }
    .label {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.6875rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--text-tertiary);
    }
    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 24px;
    }
    @media (min-width: 768px) { .container { padding: 0 40px; } }
    @media (min-width: 1024px) { .container { padding: 0 48px; } }

    /* Particle canvas */
    #particle-canvas {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      z-index: 0;
      pointer-events: none;
    }
    .page-content {
      position: relative;
      z-index: 1;
    }

    /* Reveal animations */
    .reveal {
      opacity: 0;
      transform: translateY(12px);
      transition: opacity 0.6s ease, transform 0.6s ease;
    }
    .reveal.visible {
      opacity: 1;
      transform: translateY(0);
    }

    /* Mobile menu */
    .mobile-menu { display: none; }
    .mobile-menu.active { display: block; }
  </style>
</head>
<body>

  <!-- PARTICLE CANVAS -->
  <canvas id="particle-canvas"></canvas>

  <div class="page-content">

  <!-- NAVIGATION -->
  <nav style="position: fixed; top: 0; left: 0; right: 0; z-index: 50; background: var(--nav-bg); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); border-bottom: 1px solid var(--border); height: 56px;">
    <div class="container" style="display: flex; align-items: center; justify-content: space-between; height: 100%;">
      <a href={base + "/8/"} style="display: flex; align-items: center; gap: 10px;">
        <img src="/brand/aosus-icon.svg" alt="أسس" style="width: 28px; height: 28px;" />
        <span style="font-weight: 600; font-size: 1.125rem;">أسس</span>
      </a>
      <div style="display: none; align-items: center; gap: 28px; font-size: 0.8125rem; color: var(--text-secondary);" class="nav-links-desktop">
        <a href="#about" style="transition: color 0.2s;" onmouseover="this.style.color='var(--text)'" onmouseout="this.style.color='var(--text-secondary)'">من نحن</a>
        <a href="#services" style="transition: color 0.2s;" onmouseover="this.style.color='var(--text)'" onmouseout="this.style.color='var(--text-secondary)'">الخدمات</a>
        <a href="#contest" style="transition: color 0.2s;" onmouseover="this.style.color='var(--text)'" onmouseout="this.style.color='var(--text-secondary)'">الجائزة</a>
        <a href="#timeline" style="transition: color 0.2s;" onmouseover="this.style.color='var(--text)'" onmouseout="this.style.color='var(--text-secondary)'">تاريخنا</a>
        <a href="#projects" style="transition: color 0.2s;" onmouseover="this.style.color='var(--text)'" onmouseout="this.style.color='var(--text-secondary)'">المشاريع</a>
        <a href="#support" style="transition: color 0.2s;" onmouseover="this.style.color='var(--text)'" onmouseout="this.style.color='var(--text-secondary)'">ادعمنا</a>
      </div>
      <div style="display: flex; align-items: center; gap: 4px;">
        <button id="theme-toggle" style="width: 36px; height: 36px; display: flex; align-items: center; justify-content: center; background: none; border: none; color: var(--text-secondary); cursor: pointer;" aria-label="تبديل المظهر">
          <svg class="theme-moon" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z" /></svg>
          <svg class="theme-sun" style="display:none;" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="4" /><path d="M12 2v2m0 16v2M4.93 4.93l1.41 1.41m11.32 11.32l1.41 1.41M2 12h2m16 0h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41" /></svg>
        </button>
        <button id="mobile-toggle" style="display: none; width: 36px; height: 36px; align-items: center; justify-content: center; background: none; border: none; color: var(--text-secondary); cursor: pointer;" class="mobile-toggle-btn" aria-label="القائمة">
          <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M3.75 9h16.5m-16.5 6h16.5" /></svg>
        </button>
      </div>
    </div>
    <div id="mobile-menu" class="mobile-menu" style="background: var(--nav-bg); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); border-bottom: 1px solid var(--border); padding: 0 24px 16px;">
      <div style="display: flex; flex-direction: column; font-size: 0.875rem; color: var(--text-secondary);">
        <a href="#about" style="padding: 10px 0; border-bottom: 1px solid var(--border-light);">من نحن</a>
        <a href="#services" style="padding: 10px 0; border-bottom: 1px solid var(--border-light);">الخدمات</a>
        <a href="#contest" style="padding: 10px 0; border-bottom: 1px solid var(--border-light);">الجائزة</a>
        <a href="#timeline" style="padding: 10px 0; border-bottom: 1px solid var(--border-light);">تاريخنا</a>
        <a href="#projects" style="padding: 10px 0; border-bottom: 1px solid var(--border-light);">المشاريع</a>
        <a href="#support" style="padding: 10px 0;">ادعمنا</a>
      </div>
    </div>
  </nav>

  <!-- HERO -->
  <section style="padding-top: 56px;">
    <div class="container">
      <div style="padding: 100px 0 60px; border-bottom: 1px solid var(--border);">
        <div class="reveal">
          <span class="label" style="display: block; margin-bottom: 24px;">مجتمع مفتوح المصدر</span>
          <h1 style="font-size: clamp(2.5rem, 6vw, 5rem); font-weight: 700; line-height: 1.12; margin: 0 0 32px; max-width: 820px; letter-spacing: -0.01em;">
            أكبر مجتمع عربي
            <br />للبرمجيات الحرة
            <br /><span style="color: var(--text-secondary);">والمفتوحة المصدر</span>
          </h1>
          <p style="font-size: 1.0625rem; color: var(--text-secondary); line-height: 1.85; max-width: 560px; margin: 0 0 48px;">
            مجتمع غير ربحي أسسه مجموعة من التقنيين العرب بهدف نشر ثقافة المصادر المفتوحة والبرمجيات الحرة في العالم العربي
          </p>
        </div>
        <div class="reveal" style="display: flex; flex-wrap: wrap; gap: 12px;">
          <a href="https://discourse.aosus.org" style="display: inline-flex; align-items: center; padding: 11px 32px; background: var(--green); color: #fff; font-size: 0.875rem; font-weight: 500; transition: background 0.2s;" onmouseover="this.style.background='var(--green-hover)'" onmouseout="this.style.background='var(--green)'">
            انضم للمجتمع
          </a>
          <a href="#about" style="display: inline-flex; align-items: center; padding: 11px 32px; border: 1px solid var(--border); font-size: 0.875rem; color: var(--text-secondary); transition: border-color 0.2s, color 0.2s;" onmouseover="this.style.borderColor='var(--text)';this.style.color='var(--text)'" onmouseout="this.style.borderColor='var(--border)';this.style.color='var(--text-secondary)'">
            تعرّف علينا
          </a>
        </div>
      </div>

      <!-- Stats -->
      <div class="reveal stats-grid" style="display: grid; grid-template-columns: repeat(4, 1fr);">
        <div style="padding: 36px 0; border-bottom: 1px solid var(--border);">
          <div class="mono" style="font-size: clamp(2rem, 4vw, 3.25rem); font-weight: 500; letter-spacing: -0.03em;">6,000<span style="color: var(--green);">+</span></div>
          <div class="label" style="margin-top: 8px;">عضو</div>
        </div>
        <div style="padding: 36px 24px; border-bottom: 1px solid var(--border); border-right: 1px solid var(--border);">
          <div class="mono" style="font-size: clamp(2rem, 4vw, 3.25rem); font-weight: 500; letter-spacing: -0.03em;">5,000<span style="color: var(--green);">+</span></div>
          <div class="label" style="margin-top: 8px;">مشاركة</div>
        </div>
        <div style="padding: 36px 24px; border-bottom: 1px solid var(--border); border-right: 1px solid var(--border);">
          <div class="mono" style="font-size: clamp(2rem, 4vw, 3.25rem); font-weight: 500; letter-spacing: -0.03em;">10</div>
          <div class="label" style="margin-top: 8px;">سنوات</div>
        </div>
        <div style="padding: 36px 24px; border-bottom: 1px solid var(--border); border-right: 1px solid var(--border);">
          <div class="mono" style="font-size: clamp(2rem, 4vw, 3.25rem); font-weight: 500; letter-spacing: -0.03em;">3,000<span style="color: var(--green);">+</span></div>
          <div class="label" style="margin-top: 8px;">موضوع</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ABOUT -->
  <section id="about" style="padding: 100px 0;">
    <div class="container">
      <div style="border-bottom: 1px solid var(--border); padding-bottom: 100px;">
        <div class="reveal">
          <span class="label" style="display: block; margin-bottom: 20px;">01 — من نحن</span>
          <h2 style="font-size: clamp(1.875rem, 4vw, 3rem); font-weight: 700; line-height: 1.2; margin: 0 0 20px;">نبني مجتمعاً عربياً مفتوح المصدر</h2>
          <p style="font-size: 1rem; color: var(--text-secondary); line-height: 1.9; max-width: 640px; margin: 0 0 64px;">
            نسعى لنشر ثقافة البرمجيات الحرة والمفتوحة المصدر في العالم العربي. نؤمن بأن التقنية يجب أن تكون متاحة للجميع وأن المعرفة حق مشترك.
          </p>
        </div>

        <!-- Vision & Mission -->
        <div class="reveal vision-grid" style="display: grid; grid-template-columns: 1fr 1fr; gap: 0; margin-bottom: 48px;">
          <div style="padding: 32px; border: 1px solid var(--border);">
            <span class="label" style="display: block; margin-bottom: 14px;">الرؤية</span>
            <p style="font-size: 0.9375rem; color: var(--text-secondary); line-height: 1.8; margin: 0;">
              أن يكون العالم العربي رائداً في استخدام وتطوير البرمجيات الحرة والمفتوحة المصدر
            </p>
          </div>
          <div style="padding: 32px; border: 1px solid var(--border); border-right: none;">
            <span class="label" style="display: block; margin-bottom: 14px;">الرسالة</span>
            <p style="font-size: 0.9375rem; color: var(--text-secondary); line-height: 1.8; margin: 0;">
              نشر ثقافة المصادر المفتوحة والبرمجيات الحرة وتعزيز استخدامها في المجتمع العربي
            </p>
          </div>
        </div>

        <!-- Values -->
        <div class="reveal values-grid" style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 0;">
          <div style="padding: 28px; border: 1px solid var(--border);">
            <div style="width: 6px; height: 6px; background: var(--green); margin-bottom: 16px;"></div>
            <div style="font-weight: 600; margin-bottom: 6px;">التعاون</div>
            <div style="font-size: 0.8125rem; color: var(--text-tertiary); line-height: 1.7;">العمل الجماعي أساس نجاحنا</div>
          </div>
          <div style="padding: 28px; border: 1px solid var(--border); border-right: none;">
            <div style="width: 6px; height: 6px; background: var(--green); margin-bottom: 16px;"></div>
            <div style="font-weight: 600; margin-bottom: 6px;">الشفافية</div>
            <div style="font-size: 0.8125rem; color: var(--text-tertiary); line-height: 1.7;">الوضوح في كل ما نقوم به</div>
          </div>
          <div style="padding: 28px; border: 1px solid var(--border); border-right: none;">
            <div style="width: 6px; height: 6px; background: var(--green); margin-bottom: 16px;"></div>
            <div style="font-weight: 600; margin-bottom: 6px;">الخصوصية</div>
            <div style="font-size: 0.8125rem; color: var(--text-tertiary); line-height: 1.7;">حماية بيانات المستخدمين</div>
          </div>
          <div style="padding: 28px; border: 1px solid var(--border); border-right: none;">
            <div style="width: 6px; height: 6px; background: var(--green); margin-bottom: 16px;"></div>
            <div style="font-weight: 600; margin-bottom: 6px;">المسؤولية</div>
            <div style="font-size: 0.8125rem; color: var(--text-tertiary); line-height: 1.7;">التزامنا تجاه المجتمع</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section id="services" style="background: var(--bg-alt); padding: 100px 0;">
    <div class="container">
      <div class="reveal">
        <span class="label" style="display: block; margin-bottom: 20px;">02 — الخدمات</span>
        <h2 style="font-size: clamp(1.875rem, 4vw, 3rem); font-weight: 700; line-height: 1.2; margin: 0 0 16px;">خدمات مجانية تحترم خصوصيتك</h2>
        <p style="font-size: 1rem; color: var(--text-secondary); line-height: 1.8; max-width: 560px; margin: 0 0 56px;">
          نقدم بدائل مفتوحة المصدر تحترم خصوصيتك للخدمات المغلقة الأكثر استخداماً
        </p>
      </div>

      <div class="reveal" style="border: 1px solid var(--border);">
        <div class="services-grid" style="display: grid; grid-template-columns: 1fr 1fr 1fr;">
          <a href="https://search.aosus.org" target="_blank" rel="noopener" style="padding: 28px; border-bottom: 1px solid var(--border); display: block; transition: background 0.2s;" onmouseover="this.style.background='var(--bg)'" onmouseout="this.style.background='transparent'">
            <div class="mono" style="font-size: 0.6875rem; color: var(--text-tertiary); margin-bottom: 10px;">01</div>
            <div style="font-weight: 600; margin-bottom: 6px;">SearXNG</div>
            <div style="font-size: 0.8125rem; color: var(--text-secondary);">محرك بحث يحترم الخصوصية</div>
          </a>
          <a href="https://translate.aosus.org" target="_blank" rel="noopener" style="padding: 28px; border-bottom: 1px solid var(--border); border-right: 1px solid var(--border); display: block; transition: background 0.2s;" onmouseover="this.style.background='var(--bg)'" onmouseout="this.style.background='transparent'">
            <div class="mono" style="font-size: 0.6875rem; color: var(--text-tertiary); margin-bottom: 10px;">02</div>
            <div style="font-weight: 600; margin-bottom: 6px;">Simply Translate</div>
            <div style="font-size: 0.8125rem; color: var(--text-secondary);">ترجمة نصوص بدون تتبع</div>
          </a>
          <a href="https://nitter.aosus.org" target="_blank" rel="noopener" style="padding: 28px; border-bottom: 1px solid var(--border); border-right: 1px solid var(--border); display: block; transition: background 0.2s;" onmouseover="this.style.background='var(--bg)'" onmouseout="this.style.background='transparent'">
            <div class="mono" style="font-size: 0.6875rem; color: var(--text-tertiary); margin-bottom: 10px;">03</div>
            <div style="font-weight: 600; margin-bottom: 6px;">Nitter</div>
            <div style="font-size: 0.8125rem; color: var(--text-secondary);">واجهة بديلة لتويتر</div>
          </a>
          <a href="https://redlib.aosus.org" target="_blank" rel="noopener" style="padding: 28px; border-bottom: 1px solid var(--border); display: block; transition: background 0.2s;" onmouseover="this.style.background='var(--bg)'" onmouseout="this.style.background='transparent'">
            <div class="mono" style="font-size: 0.6875rem; color: var(--text-tertiary); margin-bottom: 10px;">04</div>
            <div style="font-weight: 600; margin-bottom: 6px;">Redlib</div>
            <div style="font-size: 0.8125rem; color: var(--text-secondary);">واجهة بديلة لريديت</div>
          </a>
          <a href="https://element.aosus.org" target="_blank" rel="noopener" style="padding: 28px; border-bottom: 1px solid var(--border); border-right: 1px solid var(--border); display: block; transition: background 0.2s;" onmouseover="this.style.background='var(--bg)'" onmouseout="this.style.background='transparent'">
            <div class="mono" style="font-size: 0.6875rem; color: var(--text-tertiary); margin-bottom: 10px;">05</div>
            <div style="font-weight: 600; margin-bottom: 6px;">Element</div>
            <div style="font-size: 0.8125rem; color: var(--text-secondary);">تطبيق محادثة مشفر</div>
          </a>
          <a href="https://rimgo.aosus.org" target="_blank" rel="noopener" style="padding: 28px; border-bottom: 1px solid var(--border); border-right: 1px solid var(--border); display: block; transition: background 0.2s;" onmouseover="this.style.background='var(--bg)'" onmouseout="this.style.background='transparent'">
            <div class="mono" style="font-size: 0.6875rem; color: var(--text-tertiary); margin-bottom: 10px;">06</div>
            <div style="font-weight: 600; margin-bottom: 6px;">rimgo</div>
            <div style="font-size: 0.8125rem; color: var(--text-secondary);">واجهة بديلة لإمجر</div>
          </a>
          <a href="https://scribe.aosus.org" target="_blank" rel="noopener" style="padding: 28px; display: block; transition: background 0.2s;" onmouseover="this.style.background='var(--bg)'" onmouseout="this.style.background='transparent'">
            <div class="mono" style="font-size: 0.6875rem; color: var(--text-tertiary); margin-bottom: 10px;">07</div>
            <div style="font-weight: 600; margin-bottom: 6px;">Scribe</div>
            <div style="font-size: 0.8125rem; color: var(--text-secondary);">واجهة بديلة لميديم</div>
          </a>
          <a href="https://quetre.aosus.org" target="_blank" rel="noopener" style="padding: 28px; border-right: 1px solid var(--border); display: block; transition: background 0.2s;" onmouseover="this.style.background='var(--bg)'" onmouseout="this.style.background='transparent'">
            <div class="mono" style="font-size: 0.6875rem; color: var(--text-tertiary); margin-bottom: 10px;">08</div>
            <div style="font-weight: 600; margin-bottom: 6px;">Quetre</div>
            <div style="font-size: 0.8125rem; color: var(--text-secondary);">واجهة بديلة لكورا</div>
          </a>
          <a href="https://tok.aosus.org" target="_blank" rel="noopener" style="padding: 28px; border-right: 1px solid var(--border); display: block; transition: background 0.2s;" onmouseover="this.style.background='var(--bg)'" onmouseout="this.style.background='transparent'">
            <div class="mono" style="font-size: 0.6875rem; color: var(--text-tertiary); margin-bottom: 10px;">09</div>
            <div style="font-weight: 600; margin-bottom: 6px;">ProxiTok</div>
            <div style="font-size: 0.8125rem; color: var(--text-secondary);">واجهة بديلة لتيك توك</div>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- WRITING CONTEST -->
  <section id="contest" style="padding: 100px 0;">
    <div class="container">
      <div style="border-bottom: 1px solid var(--border); padding-bottom: 100px;">
        <div class="reveal contest-grid" style="display: grid; grid-template-columns: 1fr 1fr; gap: 48px; align-items: center;">
          <div>
            <span class="label" style="display: block; margin-bottom: 20px;">03 — جائزة الكتابة</span>
            <h2 style="font-size: clamp(1.875rem, 4vw, 3rem); font-weight: 700; line-height: 1.2; margin: 0 0 20px;">جائزة الكتابة الشهرية</h2>
            <p style="font-size: 1rem; color: var(--text-secondary); line-height: 1.8; margin: 0 0 32px;">
              نحفز المحتوى العربي التقني من خلال جائزة شهرية لأفضل المقالات في مجال البرمجيات الحرة والمفتوحة المصدر
            </p>
