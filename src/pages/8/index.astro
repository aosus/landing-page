---
import '../../styles/global.css';
const base = import.meta.env.GITHUB_ACTIONS ? '/landing-page' : '';
---

<html lang="ar" dir="rtl" class="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="أسس - أكبر مجتمع عربي للبرمجيات الحرة والمفتوحة المصدر" />
  <title>أسس - مجتمع البرمجيات الحرة والمفتوحة المصدر</title>
  <link rel="icon" type="image/svg+xml" href="/brand/aosus-icon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Aref+Ruqaa:wght@400;700&family=Readex+Pro:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    :root {
      --bg-dark: #060608;
      --gold: #c5a059;
      --gold-light: #e8d097;
      --gold-dim: rgba(197, 160, 89, 0.15);
      --text-main: #fdfbf7;
      --text-muted: #a3a3a3;
    }
    
    body {
      background-color: var(--bg-dark);
      color: var(--text-main);
      font-family: 'Readex Pro', sans-serif;
      overflow-x: hidden;
      margin: 0;
    }

    .font-ruqaa {
      font-family: 'Aref Ruqaa', serif;
    }

    .glass-panel {
      background: rgba(10, 10, 12, 0.55);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border: 1px solid var(--gold-dim);
      box-shadow: 0 4px 30px rgba(0, 0, 0, 0.5);
    }

    .reveal {
      opacity: 0;
      transform: translateY(30px);
      transition: opacity 1.2s cubic-bezier(0.2, 0.8, 0.2, 1), transform 1.2s cubic-bezier(0.2, 0.8, 0.2, 1);
    }
    .reveal.visible {
      opacity: 1;
      transform: translateY(0);
    }

    ::selection {
      background: rgba(197, 160, 89, 0.3);
      color: #fff;
    }

    /* Custom smooth scrolling */
    html {
      scroll-behavior: smooth;
    }
  </style>
</head>
<body class="antialiased selection:bg-[var(--gold)]/30 selection:text-white">

  <!-- BACKGROUND CANVAS -->
  <canvas id="calligraphyCanvas" class="fixed inset-0 z-0 w-full h-full pointer-events-none"></canvas>

  <!-- NAVIGATION -->
  <nav class="fixed top-6 left-1/2 -translate-x-1/2 z-50 w-[95%] max-w-5xl">
    <div class="glass-panel rounded-full px-6 py-4 flex items-center justify-between transition-all duration-300 hover:bg-[#0a0a0c]/80 hover:border-[var(--gold)]/30">
      <a href={base + "/8/"} class="flex items-center gap-3">
        <img src="/brand/aosus-icon.svg" alt="أسس" class="w-8 h-8 opacity-90 drop-shadow-[0_0_5px_rgba(197,160,89,0.3)]" />
        <span class="font-ruqaa text-2xl font-bold text-[var(--gold)]">أسس</span>
      </a>
      
      <div class="hidden md:flex items-center gap-8 text-sm font-medium text-[var(--text-muted)]">
        <a href="#about" class="hover:text-[var(--gold)] transition-colors">من نحن</a>
        <a href="#services" class="hover:text-[var(--gold)] transition-colors">الخدمات</a>
        <a href="#contest" class="hover:text-[var(--gold)] transition-colors">الجائزة</a>
        <a href="#timeline" class="hover:text-[var(--gold)] transition-colors">تاريخنا</a>
        <a href="#projects" class="hover:text-[var(--gold)] transition-colors">المشاريع</a>
        <a href="#support" class="hover:text-[var(--gold)] transition-colors">ادعمنا</a>
      </div>

      <button id="mobile-toggle" class="md:hidden w-10 h-10 flex items-center justify-center text-[var(--gold)] hover:bg-[var(--gold)]/10 rounded-full transition-colors" aria-label="القائمة">
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 9h16.5m-16.5 6h16.5" /></svg>
      </button>
    </div>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="hidden absolute top-full left-0 right-0 mt-4 glass-panel rounded-2xl p-4 flex-col gap-2 shadow-2xl border border-[var(--gold)]/20">
      <a href="#about" class="px-4 py-3 hover:bg-[var(--gold)]/10 rounded-xl text-[var(--text-muted)] hover:text-[var(--gold)] transition-colors">من نحن</a>
      <a href="#services" class="px-4 py-3 hover:bg-[var(--gold)]/10 rounded-xl text-[var(--text-muted)] hover:text-[var(--gold)] transition-colors">الخدمات</a>
      <a href="#contest" class="px-4 py-3 hover:bg-[var(--gold)]/10 rounded-xl text-[var(--text-muted)] hover:text-[var(--gold)] transition-colors">الجائزة</a>
      <a href="#timeline" class="px-4 py-3 hover:bg-[var(--gold)]/10 rounded-xl text-[var(--text-muted)] hover:text-[var(--gold)] transition-colors">تاريخنا</a>
      <a href="#projects" class="px-4 py-3 hover:bg-[var(--gold)]/10 rounded-xl text-[var(--text-muted)] hover:text-[var(--gold)] transition-colors">المشاريع</a>
      <a href="#support" class="px-4 py-3 hover:bg-[var(--gold)]/10 rounded-xl text-[var(--text-muted)] hover:text-[var(--gold)] transition-colors">ادعمنا</a>
    </div>
  </nav>

  <!-- HERO -->
  <section class="relative z-10 min-h-[100svh] flex flex-col items-center justify-center px-6 pt-32 pb-20 overflow-hidden">
    <!-- Subtle glow behind text -->
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[80vw] h-[80vh] bg-[var(--gold)]/5 rounded-full blur-[100px] pointer-events-none"></div>

    <div class="max-w-5xl mx-auto text-center relative z-10">
      <h1 class="font-ruqaa text-7xl sm:text-8xl md:text-9xl text-transparent bg-clip-text bg-gradient-to-b from-white via-[var(--gold-light)] to-[var(--gold)] leading-[1.3] mb-10 drop-shadow-xl reveal">
        أكبر مجتمع عربي<br/>
        <span class="text-[var(--gold)] opacity-90 drop-shadow-[0_0_15px_rgba(197,160,89,0.3)]">للبرمجيات الحرة</span>
      </h1>
      <p class="text-lg md:text-2xl text-[var(--text-muted)] max-w-3xl mx-auto leading-relaxed mb-16 font-light reveal">
        مجتمع غير ربحي أسسه مجموعة من التقنيين العرب بهدف نشر ثقافة المصادر المفتوحة والبرمجيات الحرة في العالم العربي
      </p>
      
      <div class="flex flex-col sm:flex-row items-center justify-center gap-6 mb-24 reveal">
        <a href="https://discourse.aosus.org" class="px-10 py-4 bg-gradient-to-l from-[var(--gold)] to-[#a8823b] text-[#060608] rounded-full text-lg font-medium hover:scale-105 transition-transform shadow-[0_0_20px_rgba(197,160,89,0.4)]">
          انضم للمجتمع
        </a>
        <a href="#about" class="px-10 py-4 glass-panel text-[var(--gold-light)] rounded-full text-lg font-medium hover:bg-[var(--gold)]/10 transition-colors border border-[var(--gold)]/30 hover:border-[var(--gold)]/60">
          تعرّف علينا
        </a>
      </div>

      <div class="flex flex-wrap items-center justify-center gap-12 md:gap-24 reveal">
        <div class="text-center group">
          <div class="font-ruqaa text-5xl md:text-7xl text-[var(--gold)] drop-shadow-[0_0_10px_rgba(197,160,89,0.2)] group-hover:scale-110 transition-transform">6000+</div>
          <div class="text-[var(--text-muted)] mt-3 text-lg font-light tracking-wide">عضو</div>
        </div>
        <div class="text-center group">
          <div class="font-ruqaa text-5xl md:text-7xl text-[var(--gold)] drop-shadow-[0_0_10px_rgba(197,160,89,0.2)] group-hover:scale-110 transition-transform">5000+</div>
          <div class="text-[var(--text-muted)] mt-3 text-lg font-light tracking-wide">مشاركة</div>
        </div>
        <div class="text-center group">
          <div class="font-ruqaa text-5xl md:text-7xl text-[var(--gold)] drop-shadow-[0_0_10px_rgba(197,160,89,0.2)] group-hover:scale-110 transition-transform">10</div>
          <div class="text-[var(--text-muted)] mt-3 text-lg font-light tracking-wide">سنوات</div>
        </div>
        <div class="text-center group">
          <div class="font-ruqaa text-5xl md:text-7xl text-[var(--gold)] drop-shadow-[0_0_10px_rgba(197,160,89,0.2)] group-hover:scale-110 transition-transform">3000+</div>
          <div class="text-[var(--text-muted)] mt-3 text-lg font-light tracking-wide">موضوع</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ABOUT -->
  <section id="about" class="relative z-10 py-32 px-6">
    <div class="max-w-5xl mx-auto glass-panel p-10 md:p-20 rounded-[3rem]">
      <h2 class="font-ruqaa text-5xl md:text-7xl text-center text-[var(--gold)] mb-16 drop-shadow-[0_0_10px_rgba(197,160,89,0.2)] reveal">من نحن</h2>
      
      <div class="grid md:grid-cols-2 gap-16 mb-20">
        <div class="reveal">
          <h3 class="text-[var(--gold-light)] text-2xl font-medium mb-6 flex items-center gap-4">
            <span class="w-10 h-px bg-[var(--gold)]/50"></span> الرؤية
          </h3>
          <p class="text-lg leading-relaxed text-[var(--text-muted)] font-light">
            نشر الوعي بأهمية البرمجيات الحرة ومفتوحة المصدر في العالم العربي، وبناء مجتمع تقني عربي متميز يساهم في تطوير ودعم المشاريع مفتوحة المصدر.
          </p>
        </div>
        <div class="reveal">
          <h3 class="text-[var(--gold-light)] text-2xl font-medium mb-6 flex items-center gap-4">
            <span class="w-10 h-px bg-[var(--gold)]/50"></span> المهمة
          </h3>
          <p class="text-lg leading-relaxed text-[var(--text-muted)] font-light">
            تقديم منصة متكاملة للنقاش والتعلم ومشاركة المعرفة حول البرمجيات الحرة والمفتوحة المصدر، وتوفير خدمات تحترم خصوصية المستخدمين.
          </p>
        </div>
      </div>
      
      <div class="h-px w-full bg-gradient-to-r from-transparent via-[var(--gold)]/30 to-transparent mb-20"></div>

      <h3 class="text-[var(--gold-light)] text-2xl font-medium mb-12 text-center reveal">القيم</h3>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-10 reveal text-center">
        <div class="hover:-translate-y-2 transition-transform duration-300">
          <h4 class="font-ruqaa text-4xl text-white mb-4">التعاون</h4>
          <p class="text-[var(--text-muted)] leading-relaxed font-light">نؤمن بقوة العمل الجماعي والتعاون المفتوح بين أعضاء المجتمع</p>
        </div>
        <div class="hover:-translate-y-2 transition-transform duration-300">
          <h4 class="font-ruqaa text-4xl text-white mb-4">الشفافية</h4>
          <p class="text-[var(--text-muted)] leading-relaxed font-light">نلتزم بالشفافية الكاملة في جميع أعمالنا وقراراتنا</p>
        </div>
        <div class="hover:-translate-y-2 transition-transform duration-300">
          <h4 class="font-ruqaa text-4xl text-white mb-4">الخصوصية</h4>
          <p class="text-[var(--text-muted)] leading-relaxed font-light">نحترم خصوصية المستخدمين ونوفر بدائل تحمي بياناتهم</p>
        </div>
        <div class="hover:-translate-y-2 transition-transform duration-300">
          <h4 class="font-ruqaa text-4xl text-white mb-4">المسؤولية</h4>
          <p class="text-[var(--text-muted)] leading-relaxed font-light">نتحمل مسؤولية بناء مجتمع تقني عربي متميز ومستدام</p>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section id="services" class="relative z-10 py-32 px-6">
    <div class="max-w-4xl mx-auto">
      <h2 class="font-ruqaa text-5xl md:text-7xl text-center text-[var(--gold)] mb-6 drop-shadow-[0_0_10px_rgba(197,160,89,0.2)] reveal">الخدمات</h2>
      <p class="text-xl text-[var(--text-muted)] text-center mb-20 max-w-2xl mx-auto font-light reveal">
        نوفر مجموعة من الخدمات البديلة التي تحترم خصوصية المستخدمين وتعتمد على البرمجيات مفتوحة المصدر
      </p>

      <div class="grid sm:grid-cols-2 gap-6 reveal">
        <!-- Service Items -->
        <a href="https://search.aosus.org" target="_blank" rel="noopener" class="group glass-panel p-6 rounded-2xl flex items-center justify-between hover:bg-[var(--gold)]/5 hover:border-[var(--gold)]/40 transition-all duration-300">
          <div>
            <h3 class="text-2xl font-medium text-white group-hover:text-[var(--gold)] transition-colors">SearXNG</h3>
            <p class="text-[var(--text-muted)] mt-2 font-light">محرك بحث يحترم الخصوصية</p>
          </div>
          <svg class="w-6 h-6 text-[var(--gold)] opacity-50 group-hover:opacity-100 group-hover:-translate-x-2 transition-all duration-300 -scale-x-100" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12h15m0 0l-6.75-6.75M19.5 12l-6.75 6.75" /></svg>
        </a>
        <a href="https://translate.aosus.org" target="_blank" rel="noopener" class="group glass-panel p-6 rounded-2xl flex items-center justify-between hover:bg-[var(--gold)]/5 hover:border-[var(--gold)]/40 transition-all duration-300">
          <div>
            <h3 class="text-2xl font-medium text-white group-hover:text-[var(--gold)] transition-colors">Simply Translate</h3>
            <p class="text-[var(--text-muted)] mt-2 font-light">ترجمة نصوص بدون تتبع</p>
          </div>
          <svg class="w-6 h-6 text-[var(--gold)] opacity-50 group-hover:opacity-100 group-hover:-translate-x-2 transition-all duration-300 -scale-x-100" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12h15m0 0l-6.75-6.75M19.5 12l-6.75 6.75" /></svg>
        </a>
        <a href="https://nitter.aosus.org" target="_blank" rel="noopener" class="group glass-panel p-6 rounded-2xl flex items-center justify-between hover:bg-[var(--gold)]/5 hover:border-[var(--gold)]/40 transition-all duration-300">
          <div>
            <h3 class="text-2xl font-medium text-white group-hover:text-[var(--gold)] transition-colors">Nitter</h3>
            <p class="text-[var(--text-muted)] mt-2 font-light">واجهة بديلة لتويتر</p>
          </div>
          <svg class="w-6 h-6 text-[var(--gold)] opacity-50 group-hover:opacity-100 group-hover:-translate-x-2 transition-all duration-300 -scale-x-100" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12h15m0 0l-6.75-6.75M19.5 12l-6.75 6.75" /></svg>
        </a>
        <a href="https://redlib.aosus.org" target="_blank" rel="noopener" class="group glass-panel p-6 rounded-2xl flex items-center justify-between hover:bg-[var(--gold)]/5 hover:border-[var(--gold)]/40 transition-all duration-300">
          <div>
            <h3 class="text-2xl font-medium text-white group-hover:text-[var(--gold)] transition-colors">Redlib</h3>
            <p class="text-[var(--text-muted)] mt-2 font-light">واجهة بديلة لريديت</p>
          </div>
          <svg class="w-6 h-6 text-[var(--gold)] opacity-50 group-hover:opacity-100 group-hover:-translate-x-2 transition-all duration-300 -scale-x-100" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12h15m0 0l-6.75-6.75M19.5 12l-6.75 6.75" /></svg>
        </a>
        <a href="https://element.aosus.org" target="_blank" rel="noopener" class="group glass-panel p-6 rounded-2xl flex items-center justify-between hover:bg-[var(--gold)]/5 hover:border-[var(--gold)]/40 transition-all duration-300">
          <div>
            <h3 class="text-2xl font-medium text-white group-hover:text-[var(--gold)] transition-colors">Element</h3>
            <p class="text-[var(--text-muted)] mt-2 font-light">تطبيق محادثة مشفر</p>
          </div>
          <svg class="w-6 h-6 text-[var(--gold)] opacity-50 group-hover:opacity-100 group-hover:-translate-x-2 transition-all duration-300 -scale-x-100" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12h15m0 0l-6.75-6.75M19.5 12l-6.75 6.75" /></svg>
        </a>
        <a href="https://rimgo.aosus.org" target="_blank" rel="noopener" class="group glass-panel p-6 rounded-2xl flex items-center justify-between hover:bg-[var(--gold)]/5 hover:border-[var(--gold)]/40 transition-all duration-300">
          <div>
            <h3 class="text-2xl font-medium text-white group-hover:text-[var(--gold)] transition-colors">rimgo</h3>
            <p class="text-[var(--text-muted)] mt-2 font-light">واجهة بديلة لإمجر</p>
          </div>
          <svg class="w-6 h-6 text-[var(--gold)] opacity-50 group-hover:opacity-100 group-hover:-translate-x-2 transition-all duration-300 -scale-x-100" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12h15m0 0l-6.75-6.75M19.5 12l-6.75 6.75" /></svg>
        </a>
        <a href="https://scribe.aosus.org" target="_blank" rel="noopener" class="group glass-panel p-6 rounded-2xl flex items-center justify-between hover:bg-[var(--gold)]/5 hover:border-[var(--gold)]/40 transition-all duration-300">
          <div>
            <h3 class="text-2xl font-medium text-white group-hover:text-[var(--gold)] transition-colors">Scribe</h3>
            <p class="text-[var(--text-muted)] mt-2 font-light">واجهة بديلة لميديم</p>
          </div>
          <svg class="w-6 h-6 text-[var(--gold)] opacity-50 group-hover:opacity-100 group-hover:-translate-x-2 transition-all duration-300 -scale-x-100" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12h15m0 0l-6.75-6.75M19.5 12l-6.75 6.75" /></svg>
        </a>
        <a href="https://quetre.aosus.org" target="_blank" rel="noopener" class="group glass-panel p-6 rounded-2xl flex items-center justify-between hover:bg-[var(--gold)]/5 hover:border-[var(--gold)]/40 transition-all duration-300">
          <div>
            <h3 class="text-2xl font-medium text-white group-hover:text-[var(--gold)] transition-colors">Quetre</h3>
            <p class="text-[var(--text-muted)] mt-2 font-light">واجهة بديلة لكورا</p>
          </div>
          <svg class="w-6 h-6 text-[var(--gold)] opacity-50 group-hover:opacity-100 group-hover:-translate-x-2 transition-all duration-300 -scale-x-100" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12h15m0 0l-6.75-6.75M19.5 12l-6.75 6.75" /></svg>
        </a>
        <a href="https://tok.aosus.org" target="_blank" rel="noopener" class="group glass-panel p-6 rounded-2xl flex items-center justify-between hover:bg-[var(--gold)]/5 hover:border-[var(--gold)]/40 transition-all duration-300">
          <div>
            <h3 class="text-2xl font-medium text-white group-hover:text-[var(--gold)] transition-colors">ProxiTok</h3>
            <p class="text-[var(--text-muted)] mt-2 font-light">واجهة بديلة لتيك توك</p>
          </div>
          <svg class="w-6 h-6 text-[var(--gold)] opacity-50 group-hover:opacity-100 group-hover:-translate-x-2 transition-all duration-300 -scale-x-100" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12h15m0 0l-6.75-6.75M19.5 12l-6.75 6.75" /></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- WRITING CONTEST -->
  <section id="contest" class="relative z-10 py-32 px-6">
    <div class="max-w-5xl mx-auto glass-panel p-10 md:p-20 rounded-[3rem] overflow-hidden relative border-[var(--gold)]/30">
      <div class="absolute -top-40 -right-40 w-96 h-96 bg-[var(--gold)]/10 rounded-full blur-[100px] pointer-events-none"></div>
      
      <div class="grid md:grid-cols-[1fr,1.2fr] gap-16 items-center relative z-10">
        <div class="reveal">
          <h2 class="font-ruqaa text-5xl md:text-7xl text-white mb-6 drop-shadow-md">جائزة الكتابة</h2>
          <p class="text-xl text-[var(--text-muted)] leading-relaxed font-light mb-10">
            مسابقة شهرية لتشجيع إنتاج المحتوى العربي التقني المتميز حول البرمجيات الحرة والمفتوحة المصدر.
          </p>
          <a href="https://discourse.aosus.org/t/15188" target="_blank" rel="noopener" class="inline-flex items-center gap-3 px-10 py-4 bg-[var(--gold)]/10 border border-[var(--gold)]/30 text-[var(--gold-light)] rounded-full text-lg hover:bg-[var(--gold)] hover:text-[#060608] hover:border-[var(--gold)] transition-all duration-300 shadow-[0_0_15px_rgba(197,160,89,0.1)]">
            شارك الآن
            <svg class="w-5 h-5 -scale-x-100" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12h15m0 0l-6.75-6.75M19.5 12l-6.75 6.75" /></svg>
          </a>
        </div>
        <div class="reveal text-center md:text-right border-t md:border-t-0 md:border-r border-[var(--gold)]/20 pt-10 md:pt-0 md:pr-16">
          <div class="font-ruqaa text-7xl md:text-9xl text-[var(--gold)] mb-6 drop-shadow-[0_0_20px_rgba(197,160,89,0.4)]">$250+</div>
