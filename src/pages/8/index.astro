  <script>
    // ── Theme Toggle ──
    const toggle = document.getElementById('theme-toggle')!;
    const html = document.documentElement;
    const moonIcon = toggle.querySelector('.theme-moon') as HTMLElement;
    const sunIcon = toggle.querySelector('.theme-sun') as HTMLElement;

    const savedTheme = localStorage.getItem('theme-8');
    const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;

    if (savedTheme === 'dark' || (!savedTheme && prefersDark)) {
      html.classList.add('dark');
      moonIcon.style.display = 'none';
      sunIcon.style.display = 'block';
    }

    toggle.addEventListener('click', () => {
      html.classList.toggle('dark');
      const isDark = html.classList.contains('dark');
      moonIcon.style.display = isDark ? 'none' : 'block';
      sunIcon.style.display = isDark ? 'block' : 'none';
      localStorage.setItem('theme-8', isDark ? 'dark' : 'light');
    });

    // ── Mobile Menu ──
    const mobileToggle = document.getElementById('mobile-toggle')!;
    const mobileMenu = document.getElementById('mobile-menu')!;
    mobileToggle.addEventListener('click', () => {
      mobileMenu.classList.toggle('active');
    });
    mobileMenu.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => mobileMenu.classList.remove('active'));
    });

    // ── Scroll Reveal ──
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) entry.target.classList.add('visible');
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

    // ── Particle Canvas ──
    (function() {
      const canvas = document.getElementById('particle-canvas') as HTMLCanvasElement;
      const ctx = canvas.getContext('2d')!;
      let W = 0, H = 0;
      let mouseX = -9999, mouseY = -9999;
      const MOUSE_RADIUS = 150;
      const isMobile = window.matchMedia('(max-width: 767px)').matches;
      const PARTICLE_COUNT = isMobile ? 180 : 350;

      interface Particle {
        x: number;
        y: number;
        homeX: number;
        homeY: number;
        vx: number;
        vy: number;
        radius: number;
        isAccent: boolean;
        driftPhase: number;
        driftSpeed: number;
        driftAmpX: number;
        driftAmpY: number;
      }

      let particles: Particle[] = [];

      function resize() {
        W = canvas.width = window.innerWidth;
        H = canvas.height = window.innerHeight;
        if (particles.length > 0) {
          generateHomePositions();
        }
      }

      // Arabic letter stroke shapes — defined as arrays of line segments
      // Each letter is a set of points that define a stroke path
      function getLetterPaths(): {x: number; y: number}[][] {
        const cx = W / 2;
        const cy = H / 2;
        const scale = Math.min(W, H) / 800;
        const paths: {x: number; y: number}[][] = [];

        // Alef (ا) — vertical stroke
        paths.push(generateStroke(cx - 200 * scale, cy - 120 * scale, cx - 200 * scale, cy + 80 * scale, 20));

        // Seen (س) — wave with three teeth
        const seenY = cy + 20 * scale;
        const seenPts: {x: number; y: number}[] = [];
        for (let i = 0; i < 30; i++) {
          const t = i / 29;
          const x = cx - 120 * scale + t * 280 * scale;
          const y = seenY + Math.sin(t * Math.PI * 3) * 40 * scale;
          seenPts.push({ x, y });
        }
        paths.push(seenPts);

        // Seen baseline
        paths.push(generateStroke(cx - 120 * scale, seenY + 50 * scale, cx + 160 * scale, seenY + 50 * scale, 15));

        // Wow (و) — circular arc
        const wowPts: {x: number; y: number}[] = [];
        for (let i = 0; i < 25; i++) {
          const t = i / 24;
          const angle = Math.PI * 0.3 + t * Math.PI * 1.4;
          wowPts.push({
            x: cx + 220 * scale + Math.cos(angle) * 50 * scale,
            y: cy - 20 * scale + Math.sin(angle) * 50 * scale
          });
        }
        paths.push(wowPts);

        // Wow tail
        paths.push(generateStroke(cx + 220 * scale + 50 * scale, cy + 20 * scale, cx + 240 * scale, cy + 90 * scale, 12));

        // Dots / diacritics scattered
        paths.push([{ x: cx - 60 * scale, y: cy - 70 * scale }]);
        paths.push([{ x: cx + 40 * scale, y: cy - 70 * scale }]);
        paths.push([{ x: cx + 100 * scale, y: cy + 100 * scale }]);

        return paths;
      }

      function generateStroke(x1: number, y1: number, x2: number, y2: number, count: number): {x: number; y: number}[] {
        const pts: {x: number; y: number}[] = [];
        for (let i = 0; i < count; i++) {
          const t = i / (count - 1);
          pts.push({
            x: x1 + (x2 - x1) * t,
            y: y1 + (y2 - y1) * t
          });
        }
        return pts;
      }

      function generateHomePositions() {
        const paths = getLetterPaths();

        // Count total path points to distribute particles proportionally
        let totalPathPoints = 0;
        paths.forEach(p => totalPathPoints += p.length);

        let idx = 0;
        paths.forEach(path => {
          const count = Math.max(1, Math.round((path.length / totalPathPoints) * PARTICLE_COUNT * 0.6));
          for (let i = 0; i < count && idx < particles.length; i++) {
            // Pick a point on the path with some jitter
            const pi = Math.floor(Math.random() * path.length);
            const jitter = 20;
            particles[idx].homeX = path[pi].x + (Math.random() - 0.5) * jitter;
            particles[idx].homeY = path[pi].y + (Math.random() - 0.5) * jitter;
            idx++;
          }
        });

        // Remaining particles scatter around the viewport
        while (idx < particles.length) {
          particles[idx].homeX = Math.random() * W;
          particles[idx].homeY = Math.random() * H;
          idx++;
        }
      }

      function init() {
        particles = [];
        for (let i = 0; i < PARTICLE_COUNT; i++) {
          const p: Particle = {
            x: Math.random() * W,
            y: Math.random() * H,
            homeX: 0,
            homeY: 0,
            vx: 0,
            vy: 0,
            radius: 1 + Math.random() * 1.5,
            isAccent: Math.random() < 0.15,
            driftPhase: Math.random() * Math.PI * 2,
            driftSpeed: 0.002 + Math.random() * 0.004,
            driftAmpX: 1 + Math.random() * 2,
            driftAmpY: 1 + Math.random() * 2,
          };
          particles.push(p);
        }
        generateHomePositions();

        // Start particles at their home positions
        particles.forEach(p => {
          p.x = p.homeX + (Math.random() - 0.5) * 40;
          p.y = p.homeY + (Math.random() - 0.5) * 40;
        });
      }

      function animate() {
        ctx.clearRect(0, 0, W, H);

        const isDark = html.classList.contains('dark');
        const baseColor = isDark ? '245, 243, 235' : '10, 10, 10';
        const baseOpacity = isDark ? 0.2 : 0.14;
        const accentColor = '0, 138, 47'; // #008a2f
        const accentOpacity = isDark ? 0.28 : 0.2;

        const time = Date.now() * 0.001;

        for (let i = 0; i < particles.length; i++) {
          const p = particles[i];

          // Ambient drift
          const driftX = Math.sin(time * p.driftSpeed + p.driftPhase) * p.driftAmpX;
          const driftY = Math.cos(time * p.driftSpeed * 0.8 + p.driftPhase) * p.driftAmpY;

          const targetX = p.homeX + driftX;
          const targetY = p.homeY + driftY;

          // Mouse repulsion
          const dx = p.x - mouseX;
          const dy = p.y - mouseY;
          const dist = Math.sqrt(dx * dx + dy * dy);

          if (dist < MOUSE_RADIUS && dist > 0) {
            const force = (MOUSE_RADIUS - dist) / MOUSE_RADIUS;
            const angle = Math.atan2(dy, dx);
            p.vx += Math.cos(angle) * force * 3;
            p.vy += Math.sin(angle) * force * 3;
          }

          // Spring force back to home
          const springX = (targetX - p.x) * 0.02;
          const springY = (targetY - p.y) * 0.02;
          p.vx += springX;
          p.vy += springY;

          // Damping
          p.vx *= 0.92;
          p.vy *= 0.92;

          p.x += p.vx;
          p.y += p.vy;

          // Draw
          const color = p.isAccent ? accentColor : baseColor;
          const opacity = p.isAccent ? accentOpacity : baseOpacity;

          ctx.beginPath();
          ctx.arc(p.x, p.y, p.radius, 0, Math.PI * 2);
          ctx.fillStyle = `rgba(${color}, ${opacity})`;
          ctx.fill();
        }

        requestAnimationFrame(animate);
      }

      // Mouse tracking — use the canvas coordinate space
      document.addEventListener('mousemove', (e) => {
        mouseX = e.clientX;
        mouseY = e.clientY;
      });

      document.addEventListener('mouseleave', () => {
        mouseX = -9999;
        mouseY = -9999;
      });

      // Touch support
      document.addEventListener('touchmove', (e) => {
        if (e.touches.length > 0) {
          mouseX = e.touches[0].clientX;
          mouseY = e.touches[0].clientY;
        }
      }, { passive: true });

      document.addEventListener('touchend', () => {
        mouseX = -9999;
        mouseY = -9999;
      });

      window.addEventListener('resize', () => {
        resize();
      });

      resize();
      init();
      animate();
    })();
  </script>

</body>
</html>
